---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Preload LCP image (WebP path under public/). */
  preloadImage?: string;
  /** When true, adds noindex to keep error pages out of search results. */
  noindex?: boolean;
  /** Full content for meta robots (e.g. "noindex, nofollow"). Overrides noindex when set. */
  robots?: string;
}

const {
  title = "Harvous — Bible notes app alternative",
  description = "Harvous is a Bible study notes app — not a Bible reader, not sermon transcription. Save scripture-linked notes and remember what you saved.",
  ogImage = "/og.png",
  jsonLd,
  preloadImage,
  noindex = false,
  robots,
} = Astro.props;

const robotsContent = robots ?? (noindex ? "noindex" : undefined);

const siteOrigin = Astro.site ?? "https://harvous.com";
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en" data-color-scheme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link
      rel="preload"
      href="/fonts/google-sans-flex/GoogleSansFlex-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <style is:inline>
      @font-face {
        font-family: "Google Sans Flex";
        src: url("/fonts/google-sans-flex/GoogleSansFlex-Variable.woff2") format("woff2-variations");
        font-weight: 1 1000;
        font-style: normal;
        font-display: swap;
      }
      html {
        font-family: "Google Sans Flex", ui-sans-serif, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
    </style>
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (() => {
        // TEMP: dark mode disabled — always light until night theme is ready to ship.
        document.documentElement.dataset.colorScheme = "light";
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    {robotsContent && <meta name="robots" content={robotsContent} />}
    <link rel="canonical" href={canonical} />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} type="image/webp" fetchpriority="high" />
    )}
    <link rel="icon" type="image/png" href="/images/harvous-2-icon.png" />
    <link rel="apple-touch-icon" href="/images/harvous-2-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Harvous" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <script src="https://cdn.usefathom.com/script.js" data-site="UOIPAZGI" defer></script>
  </head>
  <body>
    <Header />
    <div class="page-frame">
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      const stacks = document.querySelectorAll(".paper-stack");
      const reveals = document.querySelectorAll("[data-reveal]");

      const revealEl = (el: Element) => el.classList.add("revealed");
      const revealStack = (el: Element) => el.classList.add("in-view");

      /** True when any part of the element is in the viewport and layout has size. */
      const isInViewport = (el: Element) => {
        const rect = el.getBoundingClientRect();
        if (rect.width === 0 && rect.height === 0) return false;
        return rect.top < window.innerHeight && rect.bottom > 0;
      };

      const revealVisibleNow = () => {
        reveals.forEach((el) => {
          if (!el.classList.contains("revealed") && isInViewport(el)) revealEl(el);
        });
        stacks.forEach((el) => {
          if (!el.classList.contains("in-view") && isInViewport(el)) revealStack(el);
        });
      };

      if ("IntersectionObserver" in window) {
        const stackObserver = new IntersectionObserver(
          (entries, ob) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              revealStack(e.target);
              ob.unobserve(e.target);
            });
          },
          { threshold: 0, rootMargin: "0px 0px -10% 0px" }
        );

        const revealObserver = new IntersectionObserver(
          (entries, ob) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              revealEl(e.target);
              ob.unobserve(e.target);
            });
          },
          { threshold: 0, rootMargin: "0px 0px -8% 0px" }
        );

        reveals.forEach((el) => {
          if (isInViewport(el)) {
            revealEl(el);
          } else {
            revealObserver.observe(el);
          }
        });

        stacks.forEach((el) => {
          if (isInViewport(el)) {
            revealStack(el);
          } else {
            stackObserver.observe(el);
          }
        });

        // Layout/fonts/images can settle after the module runs — re-check so above-the-fold
        // content is not left at opacity: 0 until the user scrolls.
        requestAnimationFrame(() => {
          requestAnimationFrame(revealVisibleNow);
        });
        window.addEventListener("load", revealVisibleNow, { once: true });
        document.fonts?.ready.then(revealVisibleNow);
      } else {
        stacks.forEach((el) => revealStack(el));
        reveals.forEach((el) => revealEl(el));
      }

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const revealHashTarget = (hash: string) => {
        const id = hash.replace(/^#/, "");
        if (!id) return false;
        const target = document.getElementById(id);
        if (!target) return false;
        target.querySelectorAll("[data-reveal]").forEach(revealEl);
        target.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
        return true;
      };

      document.addEventListener("click", (event) => {
        const link = (event.target as Element).closest('a[href*="#"]');
        if (!link) return;
        const href = link.getAttribute("href");
        if (!href || href === "#") return;
        const hash = href.includes("#") ? href.slice(href.indexOf("#")) : "";
        if (!hash || hash === "#") return;
        if (!document.getElementById(hash.slice(1))) return;
        if (link instanceof HTMLAnchorElement && link.origin !== window.location.origin) return;
        event.preventDefault();
        history.pushState(null, "", hash);
        revealHashTarget(hash);
      });

      if (window.location.hash) {
        requestAnimationFrame(() => revealHashTarget(window.location.hash));
      }
      window.addEventListener("hashchange", () => revealHashTarget(window.location.hash));
    </script>

    <script is:inline>
      document.querySelectorAll("[data-fathom-track]").forEach(function (el) {
        el.addEventListener("click", function () {
          if (window.fathom) {
            window.fathom.trackEvent(el.getAttribute("data-fathom-track"));
          }
        });
      });
    </script>
  </body>
</html>
