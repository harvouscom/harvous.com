---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Harvous — Bible notes app alternative",
  description = "Harvous is a Bible study notes app — not a Bible reader, not sermon transcription. Save scripture-linked notes and remember what you saved.",
  ogImage = "/og.png",
  jsonLd,
} = Astro.props;

const siteOrigin = Astro.site ?? "https://harvous.com";
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("harvous-color-scheme");
          const scheme =
            stored === "light" || stored === "dark"
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.colorScheme = scheme;
        } catch (e) {
          document.documentElement.dataset.colorScheme = "light";
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/harvous-2-icon.png" />
    <link rel="apple-touch-icon" href="/images/harvous-2-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Harvous" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap"
    />

    <script src="https://cdn.usefathom.com/script.js" data-site="UOIPAZGI" defer></script>
  </head>
  <body>
    <Header />
    <div class="page-frame">
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      const stacks = document.querySelectorAll(".paper-stack");
      const reveals = document.querySelectorAll("[data-reveal]");

      if ("IntersectionObserver" in window) {
        const reveal = (el: Element, cls: string, ob: IntersectionObserver) => {
          el.classList.add(cls);
          ob.unobserve(el);
        };
        const stackObserver = new IntersectionObserver(
          (entries, ob) => {
            entries.forEach((e) => e.isIntersecting && reveal(e.target, "in-view", ob));
          },
          { threshold: 0.15, rootMargin: "0px 0px -10% 0px" }
        );
        stacks.forEach((el) => stackObserver.observe(el));

        const revealObserver = new IntersectionObserver(
          (entries, ob) => {
            entries.forEach((e) => e.isIntersecting && reveal(e.target, "revealed", ob));
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        reveals.forEach((el) => revealObserver.observe(el));
      } else {
        stacks.forEach((el) => el.classList.add("in-view"));
        reveals.forEach((el) => el.classList.add("revealed"));
      }
    </script>

    <script is:inline>
      document.querySelectorAll("[data-fathom-track]").forEach(function (el) {
        el.addEventListener("click", function () {
          if (window.fathom) {
            window.fathom.trackEvent(el.getAttribute("data-fathom-track"));
          }
        });
      });
    </script>
  </body>
</html>
