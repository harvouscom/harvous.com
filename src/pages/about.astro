---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import PageClosingCTA from "../components/PageClosingCTA.astro";
import FounderLetter from "../components/FounderLetter.astro";
import HeroVideoLightbox from "../components/HeroVideoLightbox.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import WordCycle from "../components/WordCycle.astro";
import { fathomSignup } from "../lib/fathom-events.ts";

const site = "https://harvous.com";

const beliefs = [
  {
    title: "Tools only help.",
    body: "Harvous is a tool — a memory place for Bible study — not a substitute for pastors, friends, or the Spirit.",
  },
  {
    title: "Keep your Bible app.",
    body: "Harvous sits beside the reader you already love. Notes, highlights, and scripture links live here so Sunday's thoughts can still be there on Thursday.",
  },
  {
    title: "Beauty belongs here.",
    body: "For how beautiful God is, software that helps people remember Scripture deserves care — clarity, warmth, and room to write without noise.",
  },
  {
    title: "The search is yours.",
    body: "Proverbs 25:2 says searching out a matter is the glory of kings — not having it delivered. Harvous serves the searching. It doesn't try to study for you.",
  },
  {
    title: "Education for the church.",
    bodyBefore:
      "Long-term, Harvous wants to serve how the church learns — believers studying Scripture, pastors teaching it, and churches organizing it. A tool for education, never a substitute for the body — ",
    linkHref: "/for/churches/",
    linkLabel: "read the plan for churches",
    bodyAfter: ".",
  },
] as const;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      name: "About Harvous",
      description:
        "Harvous is a place for Bible study to live — a notes hub so what you learn from Scripture doesn't disappear. Humans help humans. Tools only help.",
      url: `${site}/about/`,
      isPartOf: { "@type": "WebSite", name: "Harvous", url: site },
    },
    {
      "@type": "Organization",
      name: "Testament Made LLC",
      url: site,
      logo: `${site}/images/harvous-2-icon.png`,
      founder: {
        "@type": "Person",
        name: "Derek Castelli",
        email: "derek@harvous.com",
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Harvous", item: site },
        { "@type": "ListItem", position: 2, name: "About", item: `${site}/about/` },
      ],
    },
  ],
};
---

<BaseLayout
  title="About — Harvous"
  description="Harvous is a place for Bible study to live — a notes hub so what you learn from Scripture doesn't disappear. Humans help humans. Tools only help."
  jsonLd={jsonLd}
>
  <section>
    <PageIntro>
      <span class="eyebrow-pill">About</span>
      <h1 class="about-hero__title section-title display-xl mt-4 text-pretty">
        <span class="about-hero__line">A place for Bible</span>
        <span class="about-hero__line about-hero__line--tail">
          study to <WordCycle words={["live", "stick", "grow", "return", "deepen"]} />.
        </span>
      </h1>
      <p class="about-hero__lead mt-5 text-lg text-[var(--color-ink-soft)] text-pretty">
        For believers who search Scripture, pastors who teach it, and churches that learn together.
        A tool for education. Never a substitute for the body.
      </p>
    </PageIntro>
  </section>

  <!-- What Harvous is -->
  <section class="about-mission frame-divider">
    <div class="about-mission__inner">
      <div class="about-mission__shotwrap" data-reveal="scale" style="--reveal-delay: 80ms;">
        <div class="about-mission__shot-frame">
          <OptimizedImage
            class="about-mission__shot"
            src="/app-full.png"
            alt="The Harvous app: My Home on the left and an open note on the right — scripture shown as tap-able pills, a highlighted phrase, and today's passage."
            width={2624}
            height={1360}
            loading="lazy"
          />
          <HeroVideoLightbox src="/touring-new-harvous-share.mp4" />
        </div>
      </div>
      <div class="about-mission__copy" data-reveal style="--reveal-delay: 120ms;">
        <div class="about-mission__prose">
          <p>
            Harvous is a notes app made for Bible study. Scripture-linked notes, highlights,
            and threads live here so what you notice doesn't disappear.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What we believe -->
  <section class="about-believe frame-divider" data-reveal style="--reveal-delay: 100ms;">
    <div class="about-believe__inner">
      <h2 class="section-title about-believe__heading text-pretty">
        What Harvous cares about
      </h2>
      <ul class="about-believe__list" role="list" data-reveal="stagger">
        {
          beliefs.map((belief, i) => (
            <li class="about-believe__item">
              <span class="about-believe__index" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="about-believe__title">{belief.title}</h3>
              <p class="about-believe__body">
                {"bodyBefore" in belief ? (
                  <>
                    {belief.bodyBefore}
                    <a href={belief.linkHref}>{belief.linkLabel}</a>
                    {belief.bodyAfter}
                  </>
                ) : (
                  belief.body
                )}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Founder letter — personal proof after the mission -->
  <section id="letter" class="about-letter frame-divider" data-reveal style="--reveal-delay: 120ms;">
    <div class="about-letter__head section-head" data-reveal>
      <span class="eyebrow-pill">From the founder</span>
      <h2 class="section-title text-pretty">A letter from Derek</h2>
      <p class="about-letter__lead">
        Why this exists, from the person building it.
      </p>
    </div>
    <div class="about-letter__inner">
      <FounderLetter variant="full" />
    </div>
  </section>

  <!-- Who's behind it -->
  <section class="frame-divider" data-reveal style="--reveal-delay: 140ms;">
    <div class="about-who detail-content py-14 md:py-16 text-center">
      <h2 class="section-title text-pretty">Who's behind it</h2>
      <p class="mt-4 text-[var(--color-ink-soft)] text-pretty">
        I'm making Harvous solo under Testament Made LLC — building the memory tool I needed,
        designing and shipping in public, one note at a time. Questions, bugs, or ideas: write me at
        <a
          class="underline decoration-[var(--color-rule)] underline-offset-4 hover:decoration-[var(--color-ink)]"
          href="mailto:derek@harvous.com"
        >
          derek@harvous.com
        </a>.
      </p>
      <p class="about-who__note">
        <mark>God-willing, I'll work on Harvous full-time one day with a small team — and keep at it for many years to come.</mark>
      </p>
    </div>
  </section>

  <PageClosingCTA
    heading="Give your study somewhere to live."
    lead="Sign up free and start writing notes that stay with Scripture."
    fathomTrack={fathomSignup.about}
  />
</BaseLayout>

<style>
  /* Small screens: one flowing sentence (natural wrap).
     md+: two lines — “A place for Bible” / “study to [word].” */
  .about-hero__line + .about-hero__line::before {
    content: " ";
  }
  @media (min-width: 768px) {
    .about-hero__line {
      display: block;
    }
    .about-hero__line + .about-hero__line::before {
      content: none;
    }
  }

  .about-hero__lead {
    max-width: 32rem;
    margin-inline: auto;
  }

  .detail-content {
    margin-inline: auto;
    max-width: 40rem;
    padding-inline: var(--frame-content-pad);
  }

  .about-mission {
    padding-block: clamp(2.5rem, 6vw, 4rem);
    padding-inline: var(--frame-content-pad);
    overflow: clip;
  }

  .about-mission__inner {
    margin-inline: auto;
    width: 100%;
    max-width: 56rem;
  }

  /* Relative shot stage — same role as .hero__shotwrap / .hero__shot-frame. */
  .about-mission__shotwrap {
    width: 100%;
  }

  .about-mission__shot-frame {
    position: relative;
    width: 100%;
    border-radius: clamp(16px, 2vw, 28px);
    overflow: hidden;
    box-shadow: var(--shadow-float);
  }

  .about-mission__shot,
  .about-mission__shot-frame :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 639px) {
    .about-mission__shot-frame {
      aspect-ratio: unset;
      width: 100%;
      height: calc((min(100vw, 56rem) - 2 * var(--frame-content-pad)) * 1360 / 2624);
    }
    .about-mission__shot-frame :global(picture) {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
    }
    .about-mission__shot,
    .about-mission__shot-frame :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top left;
    }
  }

  /* Darken bottom-left so the "Watch the tour" callout reads clearly. */
  .about-mission__shot-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    border-radius: inherit;
    background:
      radial-gradient(
        ellipse 90% 75% at 6% 96%,
        color-mix(in srgb, #0d0e12 52%, transparent) 0%,
        color-mix(in srgb, #0d0e12 22%, transparent) 38%,
        transparent 62%
      ),
      linear-gradient(
        28deg,
        color-mix(in srgb, #0d0e12 28%, transparent) 0%,
        transparent 45%
      );
  }

  .about-mission__copy {
    margin: clamp(2rem, 4.5vw, 3rem) auto 0;
    max-width: 40rem;
    text-align: center;
  }

  .about-mission__prose {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .about-mission__prose p {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  /* Full-bleed clip so the paper-stack fan can't force horizontal page scroll. */
  .about-letter {
    overflow-x: clip;
  }

  .about-letter__head {
    margin-inline: auto;
    max-width: 40rem;
    padding: clamp(3rem, 7vw, 4.5rem) var(--frame-content-pad) 0;
    text-align: center;
  }

  .about-letter__lead {
    margin: 0.75rem auto 0;
    max-width: 28rem;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  .about-letter__inner {
    margin-inline: auto;
    max-width: 64rem;
    padding: clamp(2rem, 5vw, 3rem) var(--frame-content-pad) clamp(3.5rem, 7vw, 5rem);
  }

  .about-believe__inner {
    margin-inline: auto;
    max-width: 64rem;
    padding: clamp(3rem, 7vw, 5rem) var(--frame-content-pad);
  }

  .about-believe__heading {
    margin-inline: auto;
    text-align: center;
  }

  .about-believe__list {
    list-style: none;
    margin: clamp(2.25rem, 5vw, 3.25rem) 0 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .about-believe__item {
    display: grid;
    gap: 0.65rem 1.5rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .about-believe__item:last-child {
    padding-bottom: 0;
  }

  .about-believe__index {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .about-believe__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  .about-believe__body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  .about-believe__body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in oklab, var(--color-accent) 35%, transparent);
  }

  .about-believe__body a:hover {
    text-decoration-color: var(--color-accent);
  }

  .about-who > p:not(.about-who__note) {
    font-size: 1.0625rem;
    line-height: 1.65;
  }

  .about-who__note {
    margin: 1.25rem auto 0;
    max-width: 22rem;
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .about-believe__item {
      grid-template-columns: 2.5rem minmax(0, 1fr) minmax(0, 1.35fr);
      align-items: start;
      gap: 1.25rem 2rem;
      padding-block: 1.75rem;
    }

    .about-believe__title {
      font-size: 1.35rem;
    }
  }
</style>
