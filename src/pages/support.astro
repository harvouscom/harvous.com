---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import FaqItem from "../components/FaqItem.astro";
import { getCollection, render } from "astro:content";
import { readFileSync } from "node:fs";

const APP_SUPPORT_URL = "https://app.harvous.com/settings/support";
const SUPPORT_EMAIL = "derek@harvous.com";
const mailtoHref = `mailto:${SUPPORT_EMAIL}?subject=${encodeURIComponent("Harvous support")}`;

const entries = (await getCollection("faq")).sort((a, b) => a.data.order - b.data.order);
const faqItems = await Promise.all(
  entries.map(async (f) => {
    const { Content } = await render(f);
    return { data: f.data, Content, filePath: f.filePath };
  })
);

function faqAnswerPlainText(filePath: string): string {
  const raw = readFileSync(filePath, "utf-8");
  return raw
    .replace(/^---[\s\S]*?---\s*/, "")
    .replace(/[#>*_`\[\]()]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: "Harvous Support",
      description: "Get help with Harvous — FAQs, email support, and in-app support for signed-in users.",
      url: "https://harvous.com/support/",
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map(({ data, filePath }) => ({
        "@type": "Question",
        name: data.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faqAnswerPlainText(filePath) || data.question,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title="Support — Harvous"
  description="Get help with Harvous — FAQs, email support, and in-app support for signed-in users."
  jsonLd={jsonLd}
>
  <section class="support-page frame-divider">
    <Container size="md">
      <header class="support-page__head">
        <span class="eyebrow-pill">Help</span>
        <h1 class="section-title">Support</h1>
        <p class="support-page__lead">
          Questions, bugs, or ideas — reach out by email or through the app. I read everything myself.
        </p>
        <p class="support-page__byline">— Derek, the founder</p>
      </header>

      <div class="support-page__contact">
        <article class="support-contact-card support-contact-card--email">
          <span class="support-contact-card__label">Email</span>
          <a href={mailtoHref} class="support-contact-card__title">{SUPPORT_EMAIL}</a>
          <p class="support-contact-card__detail">
            Best for account questions, billing, or anything you prefer to send from your mail app.
          </p>
          <button
            type="button"
            class="btn-pill support-contact-card__copy"
            data-copy-email={SUPPORT_EMAIL}
            aria-label="Copy email address"
          >
            <svg class="support-contact-card__copy-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="5.5" y="5.5" width="8" height="8" rx="1.2"/>
              <path d="M10.5 5.5V4.8a1.3 1.3 0 0 0-1.3-1.3H3.8a1.3 1.3 0 0 0-1.3 1.3v5.4a1.3 1.3 0 0 0 1.3 1.3h.7"/>
            </svg>
            <svg class="support-contact-card__copy-icon support-contact-card__copy-icon--check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3.5 8.5l3 3 6-6"/>
            </svg>
            <span class="support-contact-card__copy-label">Copy email</span>
          </button>
        </article>

        <a href={APP_SUPPORT_URL} class="support-contact-card">
          <span class="support-contact-card__label">In the app</span>
          <span class="support-contact-card__title">Settings → Support</span>
          <span class="support-contact-card__detail">
            Signed-in users can send bug reports, ideas, and questions with app version and device context attached.
          </span>
          <span class="support-contact-card__meta">Opens app.harvous.com</span>
        </a>
      </div>

      {
        faqItems.length > 0 && (
          <div class="support-page__faq">
            <h2 class="support-page__faq-title">Common questions</h2>
            <div class="support-page__faq-list">
              {faqItems.map(({ data, Content }) => (
                <FaqItem question={data.question}>
                  <Content />
                </FaqItem>
              ))}
            </div>
          </div>
        )
      }
    </Container>
  </section>
</BaseLayout>

<script>
  const copyButtons = document.querySelectorAll<HTMLButtonElement>("[data-copy-email]");

  for (const button of copyButtons) {
    button.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const email = button.dataset.copyEmail;
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        button.classList.add("is-copied");
        button.setAttribute("aria-label", "Copied email address");
        const label = button.querySelector(".support-contact-card__copy-label");
        if (label) label.textContent = "Copied";

        window.setTimeout(() => {
          button.classList.remove("is-copied");
          button.setAttribute("aria-label", "Copy email address");
          if (label) label.textContent = "Copy email";
        }, 2000);
      } catch {
        button.setAttribute("aria-label", "Could not copy email address");
      }
    });
  }
</script>

<style>
  .support-page {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .support-page__head {
    text-align: center;
  }
  .support-page__lead {
    margin-top: 0.75rem;
    max-width: 28rem;
    margin-inline: auto;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .support-page__byline {
    margin-top: 0.65rem;
    max-width: 28rem;
    margin-inline: auto;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-ink-faint);
  }

  .support-page__contact {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: clamp(2.25rem, 5vw, 3rem);
    max-width: 34rem;
    margin-inline: auto;
  }
  @media (min-width: 640px) {
    .support-page__contact {
      grid-template-columns: 1fr 1fr;
    }
  }

  .support-contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.15rem 1.2rem 1.25rem;
    border-radius: 2px;
    background-color: var(--paper-sheet);
    background-image:
      radial-gradient(var(--pds-paper-grain-a) 1px, transparent 1px),
      radial-gradient(var(--pds-paper-grain-b) 1px, transparent 1px);
    background-size: 28px 28px, 17px 17px;
    background-position: 0 0, 9px 9px;
    text-decoration: none;
    color: inherit;
    transition: background-color 150ms ease, transform 150ms ease;
  }
  .support-contact-card:hover {
    background-color: color-mix(in oklab, var(--color-highlight) 18%, var(--paper-sheet));
    transform: translateY(-1px);
  }

  .support-contact-card__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .support-contact-card__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
  }
  .support-contact-card__title:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--color-rule) 80%, transparent);
    text-underline-offset: 3px;
  }

  .support-contact-card__copy {
    width: 100%;
    margin-top: auto;
  }
  .support-contact-card__copy-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex: none;
  }
  .support-contact-card__copy-icon--check {
    display: none;
  }
  .support-contact-card__copy.is-copied .support-contact-card__copy-icon:not(.support-contact-card__copy-icon--check) {
    display: none;
  }
  .support-contact-card__copy.is-copied .support-contact-card__copy-icon--check {
    display: block;
    color: #047857;
  }
  .support-contact-card__copy.is-copied {
    color: #047857;
  }

  .support-contact-card__detail {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }
  .support-contact-card__meta {
    margin-top: auto;
    padding-top: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-ink-faint);
  }

  .support-page__faq {
    margin-top: clamp(3rem, 6vw, 4rem);
    max-width: 34rem;
    margin-inline: auto;
  }
  .support-page__faq-title {
    margin: 0 0 0.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-align: center;
  }
  .support-page__faq-list {
    margin-top: 1.25rem;
  }
  .support-page__faq-list :global(.faq:last-child) {
    border-bottom: 1px solid var(--color-rule);
  }
</style>
