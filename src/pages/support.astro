---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import FaqItem from "../components/FaqItem.astro";
import SupportContactCards from "../components/SupportContactCards.astro";
import { getCollection, render } from "astro:content";
import { readFileSync } from "node:fs";

const entries = (await getCollection("faq")).sort((a, b) => a.data.order - b.data.order);
const faqItems = await Promise.all(
  entries.map(async (f) => {
    const { Content } = await render(f);
    return { data: f.data, Content, filePath: f.filePath };
  })
);

function faqAnswerPlainText(filePath: string): string {
  const raw = readFileSync(filePath, "utf-8");
  return raw
    .replace(/^---[\s\S]*?---\s*/, "")
    .replace(/[#>*_`\[\]()]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: "Harvous Support",
      description: "Get help with Harvous — FAQs, email support, and in-app support for signed-in users.",
      url: "https://harvous.com/support/",
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map(({ data, filePath }) => ({
        "@type": "Question",
        name: data.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faqAnswerPlainText(filePath) || data.question,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title="Support — Harvous"
  description="Get help with Harvous — FAQs, email support, and in-app support for signed-in users."
  jsonLd={jsonLd}
>
  <section class="support-page frame-divider">
    <Container size="md">
      <header class="support-page__head" data-reveal>
        <span class="eyebrow-pill">Help</span>
        <h1 class="section-title">Support</h1>
        <p class="support-page__lead">
          Questions, bugs, or ideas — reach out by email or through the app. I read everything myself.
        </p>
        <p class="support-page__byline">— Derek, the founder</p>
      </header>

      <div class="support-page__cards" data-reveal style="--reveal-delay: 80ms;">
        <SupportContactCards />
      </div>

      {
        faqItems.length > 0 && (
          <div class="support-page__faq" data-reveal style="--reveal-delay: 140ms;">
            <h2 class="support-page__faq-title">Common questions</h2>
            <div class="support-page__faq-list">
              {faqItems.map(({ data, Content }) => (
                <FaqItem question={data.question}>
                  <Content />
                </FaqItem>
              ))}
            </div>
          </div>
        )
      }
    </Container>
  </section>
</BaseLayout>

<style>
  .support-page {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .support-page__head {
    text-align: center;
  }
  .support-page__lead {
    margin-top: 0.75rem;
    max-width: 28rem;
    margin-inline: auto;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .support-page__byline {
    margin-top: 0.65rem;
    max-width: 28rem;
    margin-inline: auto;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-ink-faint);
  }

  .support-page__cards {
    margin-top: clamp(2.25rem, 5vw, 3rem);
    max-width: 34rem;
    margin-inline: auto;
  }

  .support-page__faq {
    margin-top: clamp(3rem, 6vw, 4rem);
    max-width: 34rem;
    margin-inline: auto;
  }
  .support-page__faq-title {
    margin: 0 0 0.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-align: center;
  }
  .support-page__faq-list {
    margin-top: 1.25rem;
  }
  .support-page__faq-list :global(.faq:last-child) {
    border-bottom: 1px solid var(--color-rule);
  }
</style>
