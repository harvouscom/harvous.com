---
import BaseLayout from "../layouts/BaseLayout.astro";

const updated = "June 30, 2025";
---

<BaseLayout
  title="Terms of Service — Harvous"
  description="Terms for using Harvous, a Bible study notes app."
>
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center md:py-24">
      <div class="text-xs uppercase tracking-[0.14em] text-[var(--color-ink-faint)]">Legal</div>
      <h1 class="mt-3 font-display text-5xl leading-[1.0] md:text-6xl">Terms of Service</h1>
      <p class="mt-4 text-sm text-[var(--color-ink-faint)]">Last updated {updated}</p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-16 md:py-20">
    <div class="prose-letter space-y-8">
      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Agreement</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          These Terms of Service ("Terms") govern your use of Harvous, a Bible study notes app
          operated by Testament Made LLC. By creating an account or using Harvous, you agree to these
          Terms. If you do not agree, do not use the service.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">The service</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Harvous helps you write, organize, and revisit Bible study notes. We may update, improve,
          or discontinue features from time to time. We try to keep the service available, but we do
          not guarantee uninterrupted access.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Your account</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          You are responsible for your account credentials and for activity under your account. Keep
          your sign-in information secure and notify us if you suspect unauthorized access.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Your content</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          You retain ownership of the notes and other content you create. You grant us a limited
          license to host, store, and display your content solely to operate Harvous — including
          syncing it across your devices and honoring share links you create.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Acceptable use</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Use Harvous lawfully and respectfully. Do not upload content that is illegal, harassing,
          hateful, or that infringes someone else's rights. Do not attempt to disrupt the service,
          scrape it at scale, reverse engineer it, or access other users' private data without
          permission.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Scripture and study content</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Harvous is a tool for personal Bible study. It is not a substitute for church community,
          pastoral counsel, or your own judgment. Bible text and reference tools are provided for
          study convenience; translation and interpretation remain your responsibility.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Disclaimer</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Harvous is provided "as is" without warranties of any kind, to the fullest extent permitted
          by law. We are not liable for indirect or consequential damages arising from your use of
          the service.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Termination</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          You may stop using Harvous at any time. We may suspend or terminate access if you violate
          these Terms or if needed to protect the service or other users.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Changes</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          We may update these Terms from time to time. Continued use after changes take effect means
          you accept the updated Terms.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-ink)]">Contact</h2>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          Questions about these Terms? Email
          <a
            class="underline decoration-[var(--color-rule)] underline-offset-4 hover:decoration-[var(--color-ink)]"
            href="mailto:derek@harvous.com"
          >
            derek@harvous.com
          </a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
