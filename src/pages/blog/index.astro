---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import HubSectionNav from "../../components/HubSectionNav.astro";
import DownloadCTA from "../../components/DownloadCTA.astro";
import { getCollection } from "astro:content";
import {
  BLOG_CATEGORY_LABELS,
  includeBlogDrafts,
  isBlogPostListed,
  type BlogCategory,
} from "../../lib/blog";

const showDrafts = includeBlogDrafts();
const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => isBlogPostListed(p, showDrafts))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const featured = posts[0];
const spotlight = posts.slice(1, 5);

const categoriesInUse = [
  ...new Set(posts.map((p) => p.data.category as BlogCategory)),
].sort((a, b) => BLOG_CATEGORY_LABELS[a].localeCompare(BLOG_CATEGORY_LABELS[b]));

const topicSections = categoriesInUse.map((cat) => ({
  id: `topic-${cat}`,
  category: cat,
  label: BLOG_CATEGORY_LABELS[cat],
  posts: posts.filter((p) => p.data.category === cat),
}));

const navItems = [
  { id: "library-featured", label: "Featured" },
  ...topicSections.map((section) => ({ id: section.id, label: section.label })),
];
---

<BaseLayout
  title="Bright Enough — Harvous Blog"
  description="Bright Enough — notes, habits, and teaching that show up after Sunday. For teachers, group leaders, and anyone who keeps what they learn."
>
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-10 text-center md:py-12" data-reveal>
      <p class="eyebrow">The Harvous Blog</p>
      <h1 class="mt-4 font-display text-5xl leading-[1.0] tracking-tight md:text-7xl">
        Bright Enough
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-[var(--color-ink-soft)]">
        Notes, habits, and teaching that show up after Sunday.
      </p>
    </div>
  </section>

  {posts.length === 0 ? (
    <section class="mx-auto max-w-5xl px-5 py-16 md:py-20">
      <p class="text-center text-[var(--color-ink-soft)]">Nothing here yet. Check back soon.</p>
    </section>
  ) : (
    <div class="blog-library-main" data-hub-section-nav-main>
      <HubSectionNav
        items={navItems}
        ariaLabel="Blog topics"
        selectLabel="Jump to topic"
        selectId="blog-topic-select"
      />

      <section
        id="library-featured"
        class="mx-auto max-w-6xl py-10 md:py-14 px-[var(--frame-content-pad)]"
        data-reveal
        style="--reveal-delay: 80ms;"
        aria-labelledby="library-featured-title"
      >
        <h2 id="library-featured-title" class="sr-only">Featured</h2>
        <div class="grid gap-8 px-2 sm:px-3 lg:grid-cols-[minmax(0,1.55fr)_minmax(0,1fr)] lg:gap-10 lg:items-start lg:px-4">
          {featured && (
            <div>
              <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-ink-faint)]">
                Featured
              </p>
              <div class="rounded-[2rem] bg-[var(--color-warm)] p-2 md:p-3">
                <BlogCard
                  title={featured.data.title}
                  description={featured.data.description}
                  publishDate={featured.data.publishDate}
                  category={featured.data.category}
                  slug={featured.id}
                  readingTime={featured.data.readingTime}
                  draft={featured.data.draft}
                  variant="featured"
                />
              </div>
            </div>
          )}

          {spotlight.length > 0 && (
            <div>
              <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-ink-faint)]">
                Spotlight
              </p>
              <div class="rounded-[2rem] bg-[var(--color-warm)] p-2 md:p-3">
                <div class="flex flex-col gap-1">
                  {spotlight.map((post) => (
                    <BlogCard
                      title={post.data.title}
                      description={post.data.description}
                      publishDate={post.data.publishDate}
                      category={post.data.category}
                      slug={post.id}
                      readingTime={post.data.readingTime}
                      draft={post.data.draft}
                      variant="spotlight"
                    />
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </section>

      {topicSections.map((section, index) => (
        <section
          id={section.id}
          class:list={[index === 0 ? "frame-divider" : "border-t border-[var(--color-rule)]"]}
          aria-labelledby={`${section.id}-title`}
        >
          <div class="mx-auto max-w-3xl px-[var(--frame-content-pad)] py-14 md:py-16">
            <h2
              id={`${section.id}-title`}
              class="font-display text-3xl tracking-tight md:text-4xl"
              data-reveal
            >
              {section.label}
            </h2>
            <div class="mt-8" data-reveal style="--reveal-delay: 40ms;">
              {section.posts.map((post) => (
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  publishDate={post.data.publishDate}
                  category={post.data.category}
                  slug={post.id}
                  readingTime={post.data.readingTime}
                  draft={post.data.draft}
                  variant="story"
                />
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  )}

  <DownloadCTA />
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
