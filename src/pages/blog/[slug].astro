---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogAuthorClose from "../../components/BlogAuthorClose.astro";
import BlogCategoryIndexPage from "../../components/BlogCategoryIndexPage.astro";
import BlogTryHarvous from "../../components/BlogTryHarvous.astro";
import BlogToc from "../../components/BlogToc.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import BlogCard from "../../components/BlogCard.astro";
import {
  blogAuthorJsonLd,
  blogBreadcrumbJsonLd,
  blogCategoriesInUse,
  blogCategoryColor,
  blogCategoryHref,
  blogCategoryIcon,
  blogCategoryLabel,
  blogHeadingsFromBody,
  blogThumbUrl,
  includeBlogDrafts,
  isBlogCategory,
  isBlogPostListed,
  resolveBlogAuthor,
  type BlogCategory,
} from "../../lib/blog";
import "../../styles/use-cases.css";

type Props =
  | { kind: "category"; category: BlogCategory; currentPage: number }
  | { kind: "post"; post: CollectionEntry<"blog"> };

export async function getStaticPaths() {
  const showDrafts = includeBlogDrafts();
  const listed = (await getCollection("blog")).filter((p) => isBlogPostListed(p, showDrafts));

  for (const p of listed) {
    if (isBlogCategory(p.id)) {
      throw new Error(`Blog post id "${p.id}" collides with a category archive slug`);
    }
  }

  const postPaths = listed.map((p) => ({
    params: { slug: p.id },
    props: { kind: "post" as const, post: p },
  }));

  const categoryPaths = blogCategoriesInUse(listed).map((category) => ({
    params: { slug: category },
    props: { kind: "category" as const, category, currentPage: 1 },
  }));

  return [...postPaths, ...categoryPaths];
}

const props = Astro.props as Props;
const isCategoryArchive = props.kind === "category";

let post: CollectionEntry<"blog"> | undefined;
let Content: Awaited<ReturnType<typeof render>>["Content"] | undefined;
let tocHeadings: { depth: number; slug: string; text: string }[] = [];
let label = "";
let icon = "";
let color = { bg: "", ink: "" };
let featThumb = "";
let formattedDate = "";
let related: CollectionEntry<"blog">[] = [];
let pageUrl = "";
let pageTitle = "";
let pageDescription = "";
let publishedTime = "";
let author: ReturnType<typeof resolveBlogAuthor> | undefined;
let jsonLd: Record<string, unknown>[] | undefined;
let categoryHref = "";

if (props.kind === "post") {
  post = props.post;
  const rendered = await render(post);
  Content = rendered.Content;
  const renderedToc = rendered.headings.filter((h) => h.depth === 2);
  tocHeadings =
    renderedToc.length >= 2 ? renderedToc : blogHeadingsFromBody(post.body ?? "", 2);

  label = blogCategoryLabel(post.data.category);
  icon = blogCategoryIcon(post.data.category);
  color = blogCategoryColor(post.data.category);
  categoryHref = blogCategoryHref(post.data.category);
  featThumb = blogThumbUrl(post.id, "feat");

  formattedDate = new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(new Date(post.data.publishDate));

  const showDrafts = includeBlogDrafts();
  const allPosts = (await getCollection("blog"))
    .filter((p) => isBlogPostListed(p, showDrafts))
    .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

  const RELATED_MAX = 2;
  const RELATED_MIN = 2;

  const sameCategory = allPosts.filter(
    (p) => p.id !== post!.id && p.data.category === post!.data.category,
  );
  related = sameCategory.slice(0, RELATED_MAX);
  if (related.length < RELATED_MIN) {
    const taken = new Set([post.id, ...related.map((p) => p.id)]);
    const fillers = allPosts
      .filter((p) => !taken.has(p.id))
      .slice(0, RELATED_MIN - related.length);
    related = [...related, ...fillers];
  }

  const siteOrigin = Astro.site ?? "https://harvous.com";
  pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
  pageTitle = post.data.seoTitle ?? `${post.data.title} — Bright Enough`;
  pageDescription = post.data.seoDescription ?? post.data.description;
  publishedTime = post.data.publishDate.toISOString();
  const ogImageAbsolute = new URL(featThumb, siteOrigin).toString();
  author = resolveBlogAuthor(post.data);

  jsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: post.data.title,
      description: pageDescription,
      datePublished: publishedTime,
      image: [ogImageAbsolute],
      url: pageUrl,
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": pageUrl,
      },
      author: blogAuthorJsonLd(author, siteOrigin),
      publisher: {
        "@type": "Organization",
        name: "Harvous",
        url: siteOrigin.toString(),
        logo: {
          "@type": "ImageObject",
          url: new URL("/images/harvous-2-icon.png", siteOrigin).toString(),
        },
      },
      isPartOf: {
        "@type": "Blog",
        name: "Bright Enough",
        url: new URL("/blog/", siteOrigin).toString(),
      },
    },
    blogBreadcrumbJsonLd(
      [
        { name: "Harvous", path: "/" },
        { name: "Bright Enough", path: "/blog/" },
        { name: label, path: categoryHref },
        { name: post.data.title, path: `/blog/${post.id}/` },
      ],
      siteOrigin,
    ),
  ];
}
---

{isCategoryArchive && props.kind === "category" ? (
  <BlogCategoryIndexPage category={props.category} currentPage={props.currentPage} />
) : post && Content && author && jsonLd ? (
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={featThumb}
  ogImageWidth={1400}
  ogImageHeight={780}
  ogType="article"
  articlePublishedTime={publishedTime}
  jsonLd={jsonLd}
>
  <article data-blog-toc-main>
    <header class="border-b border-[var(--color-rule)]">
      <div class="detail-content py-10 md:py-14" data-reveal>
        <a href="/blog/" class="btn-pill inline-flex items-center gap-1.5 text-sm">
          <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M14 8a.75.75 0 0 1-.75.75H3.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L3.56 7.25H13.25A.75.75 0 0 1 14 8Z"
              clip-rule="evenodd"></path>
          </svg>
          Bright Enough
        </a>

        <div
          class="blog-post-hero__art mt-8"
          style={`background: radial-gradient(80% 70% at 18% 20%, color-mix(in oklab, ${color.bg} 85%, white) 0%, transparent 55%), linear-gradient(145deg, color-mix(in oklab, ${color.bg} 40%, var(--color-warm)), var(--color-warm));`}
        >
          <img
            src={featThumb}
            alt=""
            width={1400}
            height={780}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="blog-post-meta mt-8 flex flex-wrap items-center gap-x-2 gap-y-2 text-sm text-[var(--color-ink-faint)]">
          <a
            href={categoryHref}
            class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-faint)] transition-colors hover:text-[var(--color-accent)]"
          >
            <Icon name={icon} class="h-3.5 w-3.5" aria-hidden="true" />
            {label}
          </a>
          {post.data.draft && (
            <span class="rounded-full bg-[var(--color-ink)] px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
              Draft
            </span>
          )}
          <span class="blog-post-meta__sep" aria-hidden="true">·</span>
          <span>By {author.name}</span>
          <span class="blog-post-meta__sep" aria-hidden="true">·</span>
          <time datetime={post.data.publishDate.toISOString()}>{formattedDate}</time>
          {post.data.readingTime && (
            <>
              <span class="blog-post-meta__sep" aria-hidden="true">·</span>
              <span>{post.data.readingTime} min read</span>
            </>
          )}
        </div>

        <h1 class="section-title mt-5 text-pretty">
          {post.data.title}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-soft)]">
          {post.data.description}
        </p>
      </div>

      {/* Outside data-reveal so will-change:transform can’t trap position:fixed */}
      <div class="detail-content pb-10 md:pb-14">
        <BlogToc headings={tocHeadings} />
      </div>
    </header>

    <section class="detail-content py-12 md:py-16" data-reveal style="--reveal-delay: 80ms;">
      <div class="prose-post">
        <Content />
      </div>
      <BlogAuthorClose
        author={author}
        title={post.data.title}
        description={pageDescription}
        url={pageUrl}
      />
    </section>
  </article>

  <BlogTryHarvous category={post.data.category} featureIds={post.data.featureIds} />

  {related.length > 0 && (
    <section class="frame-divider" aria-labelledby="blog-related-title">
      <div class="mx-auto max-w-3xl px-[var(--frame-content-pad)] py-14 md:py-16">
        <h3
          id="blog-related-title"
          class="text-center font-display text-2xl tracking-tight text-[var(--color-ink)] md:text-3xl"
        >
          Keep reading in Bright Enough
        </h3>
        <div class="mt-6" data-reveal style="--reveal-delay: 40ms;">
          {related.map((p) => (
            <BlogCard
              title={p.data.title}
              description={p.data.description}
              publishDate={p.data.publishDate}
              category={p.data.category}
              slug={p.id}
              readingTime={p.data.readingTime}
              draft={p.data.draft}
              variant="story"
            />
          ))}
        </div>
        <div class="mt-8 flex justify-center">
          <a href="/blog/" class="btn-pill inline-flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M14 8a.75.75 0 0 1-.75.75H3.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L3.56 7.25H13.25A.75.75 0 0 1 14 8Z"
                clip-rule="evenodd"
              ></path>
            </svg>
            Back to Bright Enough
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
) : null}

<style>
  .blog-post-hero__art {
    position: relative;
    aspect-ratio: 2.1 / 1;
    border-radius: 1.25rem;
    overflow: hidden;
  }

  .blog-post-meta__sep {
    opacity: 0.55;
  }

  .prose-post {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink-soft);
  }

  .prose-post :global(p) {
    margin-bottom: 1.35em;
  }

  .prose-post :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose-post :global(h2),
  .prose-post :global(h3),
  .prose-post :global(h4) {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-top: 2.1em;
    margin-bottom: 0.55em;
    line-height: 1.2;
    scroll-margin-top: 5.5rem;
  }

  .prose-post :global(h2) {
    font-size: 1.55rem;
  }

  .prose-post :global(h3) {
    font-size: 1.25rem;
  }

  .prose-post :global(h4) {
    font-size: 1.1rem;
  }

  .prose-post :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: 2.25em 0;
  }

  .prose-post :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Inherit site marker highlight (testimonials / What’s Included) */
  .prose-post :global(mark) {
    background: linear-gradient(180deg, transparent 55%, var(--color-highlight) 55%);
    color: inherit;
    padding: 0 0.1em;
    border-radius: 2px;
  }

  /* Bare markdown lists only — skip component lists (e.g. BlogRoleCards) */
  .prose-post :global(p:has(+ ul:not([class]))),
  .prose-post :global(p:has(+ ol:not([class]))) {
    margin-bottom: 0.4em;
  }

  .prose-post :global(ul:not([class])) {
    list-style: none;
    margin: 0 0 1.5em;
    padding: 0;
    border: 1px solid var(--color-rule);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--color-warm) 50%, white);
    overflow: hidden;
  }

  .prose-post :global(ul:not([class]) > li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin: 0;
    padding: 0.9rem 1.2rem;
    border-top: 1px solid var(--color-rule);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .prose-post :global(ul:not([class]) > li:first-child) {
    border-top: none;
  }

  .prose-post :global(ul:not([class]) > li::before) {
    content: "";
    flex: none;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.45em;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 2.5px color-mix(in oklab, var(--color-accent) 18%, transparent);
  }

  .prose-post :global(ol:not([class])) {
    list-style: none;
    counter-reset: prose-ol;
    margin: 0 0 1.5em;
    padding: 0;
    border: 1px solid var(--color-rule);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--color-warm) 50%, white);
    overflow: hidden;
  }

  .prose-post :global(ol:not([class]) > li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    counter-increment: prose-ol;
    margin: 0;
    padding: 0.9rem 1.2rem;
    border-top: 1px solid var(--color-rule);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .prose-post :global(ol:not([class]) > li:first-child) {
    border-top: none;
  }

  .prose-post :global(ol:not([class]) > li::before) {
    content: counter(prose-ol, decimal-leading-zero);
    flex: none;
    min-width: 1.35rem;
    margin-top: 0.2em;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    line-height: 1.5;
    color: var(--color-accent);
  }

  .prose-post :global(ul:not([class]) ul),
  .prose-post :global(ol:not([class]) ol),
  .prose-post :global(ul:not([class]) ol),
  .prose-post :global(ol:not([class]) ul) {
    margin: 0.65rem 0 0.25rem;
    border: none;
    border-radius: 0.65rem;
    background: color-mix(in oklab, var(--color-card) 70%, transparent);
  }

  .prose-post :global(li > ul:not([class])),
  .prose-post :global(li > ol:not([class])) {
    margin-top: 0.55rem;
  }

  .prose-post :global(blockquote) {
    margin: 1.75em 0;
    padding: 0.15em 0 0.15em 1.15em;
    border-left: 3px solid color-mix(in oklab, var(--color-accent) 45%, var(--color-rule));
    color: var(--color-ink);
    font-style: italic;
  }

  .prose-post :global(blockquote p) {
    margin-bottom: 0.75em;
  }

  .prose-post :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose-post :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.75em 0;
    border-radius: 0.85rem;
  }

  .prose-post :global(code) {
    font-size: 0.9em;
    padding: 0.12em 0.4em;
    border-radius: 0.35rem;
    background: color-mix(in oklab, var(--color-warm) 70%, white);
    color: var(--color-ink);
  }

  /* Note-plate style — overrides Shiki github-dark inline colors on fences. */
  .prose-post :global(pre),
  .prose-post :global(pre.astro-code) {
    margin: 1.75em 0;
    padding: 1.15rem 1.25rem;
    overflow-x: auto;
    border-radius: 1rem;
    border: 1px solid var(--color-rule);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--color-cream) 50%, white) 0%,
        color-mix(in oklab, var(--color-warm) 45%, white) 100%
      ) !important;
    color: var(--color-ink) !important;
    box-shadow: var(--shadow-card);
    font-family: ui-monospace, "SF Mono", "Cascadia Code", "Segoe UI Mono", Menlo, monospace;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose-post :global(pre code),
  .prose-post :global(pre.astro-code span) {
    padding: 0;
    background: transparent !important;
    color: inherit !important;
    font-style: inherit !important;
    font-weight: inherit !important;
    text-decoration: none !important;
  }

  .prose-post :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-soft);
    text-underline-offset: 3px;
  }

  .prose-post :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }
</style>
