---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import CompareCarousel from "../../components/CompareCarousel.astro";
import CompareSectionNav from "../../components/CompareSectionNav.astro";
import PageClosingCTA from "../../components/PageClosingCTA.astro";
import IntroChip from "../../components/IntroChip.astro";
import { getCompareTypes, getCompareByType, compareTypeToId, getCompareEntries } from "../../lib/compare-data.ts";
import { getCompareGuidesForHub } from "../../lib/compare-seo-pages.ts";
import { fathomCompare, fathomSignup } from "../../lib/fathom-events.ts";
import "../../styles/compare.css";

const types = getCompareTypes();
const navItems = types.map((type) => ({ id: compareTypeToId(type), label: type }));
const compareAppCount = getCompareEntries().length;
const compareGuides = getCompareGuidesForHub();
const hasCompareGuides = compareGuides.category.length > 0 || compareGuides.alternatives.length > 0;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: "Compare Harvous",
      description:
        "See how Harvous compares to other Bible apps, notes apps, and study tools — a Bible notes alternative focused on remembering what you saved.",
      url: "https://harvous.com/compare/",
      isPartOf: { "@type": "WebSite", name: "Harvous", url: "https://harvous.com" },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Harvous", item: "https://harvous.com/" },
        { "@type": "ListItem", position: 2, name: "Compare", item: "https://harvous.com/compare/" },
      ],
    },
  ],
};
---

<BaseLayout
  title="Compare Harvous — Bible notes app alternative"
  description="Compare Harvous to YouVersion, Logos, Obsidian, Bible Note, and 40+ other apps. Harvous is notes-first — no Bible reader, no sermon transcription — built so you remember what you saved."
  jsonLd={jsonLd}
>
  <section class="compare-hub-intro frame-divider">
    <Container size="xl">
      <header class="compare-hub-intro__head section-head" data-reveal>
        <span class="eyebrow-pill">Compare</span>
        <h1 class="mt-3 font-display text-5xl leading-[1.0] md:text-7xl text-pretty">
          Where Harvous fits next to what you already use.
        </h1>
        <p class="compare-hub-intro__lead">
          Harvous is a Bible study notes app — not a Bible reader, not sermon transcription. See how it
          compares to <IntroChip><span class="tabular-nums">{compareAppCount}</span> apps</IntroChip> you might
          already use for reading, notes, or devotionals.
        </p>
      </header>
    </Container>
  </section>

  {
    hasCompareGuides && (
      <section class="compare-hub-guides frame-divider" aria-labelledby="compare-guides-title">
        <Container size="xl">
          <header class="compare-hub-guides__head" data-reveal>
            <h2 class="font-display text-2xl leading-snug md:text-3xl" id="compare-guides-title">Guides</h2>
            <p class="compare-hub-guides__lead">
              Category roundups and alternative pages — for searches like "best bible notes app" or "Logos alternative."
            </p>
          </header>

          {
            compareGuides.category.length > 0 && (
              <div class="compare-hub-guides__group" data-reveal style="--reveal-delay: 60ms;">
                <h3 class="compare-hub-guides__label">Category</h3>
                <ul class="compare-hub-guides__grid" role="list">
                  {
                    compareGuides.category.map((guide) => (
                      <li>
                        <a class="compare-hub-guides__card" href={`/compare/${guide.slug}/`} data-fathom-track={fathomCompare.hubCard}>
                          <span class="compare-hub-guides__card-title">{guide.label}</span>
                          <span class="compare-hub-guides__card-desc">{guide.description}</span>
                          <span class="compare-hub-guides__card-link">Read guide →</span>
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            )
          }

          {
            compareGuides.alternatives.length > 0 && (
              <div class="compare-hub-guides__group" data-reveal style="--reveal-delay: 100ms;">
                <h3 class="compare-hub-guides__label">Alternatives</h3>
                <ul class="compare-hub-guides__grid" role="list">
                  {
                    compareGuides.alternatives.map((guide) => (
                      <li>
                        <a class="compare-hub-guides__card" href={`/compare/${guide.slug}/`} data-fathom-track={fathomCompare.hubCard}>
                          <span class="compare-hub-guides__card-title">{guide.label}</span>
                          <span class="compare-hub-guides__card-desc">{guide.description}</span>
                          <span class="compare-hub-guides__card-link">Read guide →</span>
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            )
          }
        </Container>
      </section>
    )
  }

  <div class="compare-hub-main" data-hub-section-nav-main>
    <CompareSectionNav items={navItems} />

    {
      types.map((type, index) => {
        const sectionId = compareTypeToId(type);
        return (
          <section
            id={sectionId}
            class:list={["compare-hub__band compare-slider-band", { "frame-divider": index > 0 }]}
            aria-labelledby={`${sectionId}-title`}
          >
            <CompareCarousel
              entries={getCompareByType(type)}
              groupTitle={type}
              groupTitleId={`${sectionId}-title`}
              trackLabel={`${type} app comparisons`}
              fathomTrack={fathomCompare.hubCard}
            />
          </section>
        );
      })
    }
  </div>

  <PageClosingCTA
    heading="You've seen how Harvous compares."
    lead="Sign up free and try a notes-first Bible study app built to help you remember what you saved."
    fathomTrack={fathomSignup.compareHub}
  />
</BaseLayout>

<style>
  .compare-hub-intro {
    padding-block: clamp(3rem, 7vw, 5rem) 0;
  }
  .compare-hub-intro__lead {
    max-width: 34rem;
    margin-inline: auto;
    margin-top: 0.75rem;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .compare-hub-main {
    /* Sticky nav must share a tall ancestor with the bands it tracks. */
    position: relative;
  }
</style>
