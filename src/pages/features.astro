---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import FeatureRow from "../components/FeatureRow.astro";
import CTAButton from "../components/CTAButton.astro";
import ComparePreview from "../components/ComparePreview.astro";
import { getCollection, render } from "astro:content";
import { fathomSignup } from "../lib/fathom-events.ts";

const features = (await getCollection("features")).sort((a, b) => a.data.order - b.data.order);
const items = await Promise.all(
  features.map(async (f) => {
    const { Content } = await render(f);
    return { data: f.data, Content };
  })
);

const site = "https://harvous.com";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: "Harvous Features",
      description:
        "Harvous is a Bible study notes app — scripture pills, highlights, threads, and recall. Not a Bible reader or sermon transcription tool; built so you remember what you saved.",
      url: `${site}/features/`,
      isPartOf: { "@type": "WebSite", name: "Harvous", url: site },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Harvous", item: site },
        { "@type": "ListItem", position: 2, name: "Features", item: `${site}/features/` },
      ],
    },
    {
      "@type": "ItemList",
      name: "Harvous features",
      itemListElement: features.map((f, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: f.data.title,
        description: f.data.tagline,
      })),
    },
  ],
};
---

<BaseLayout
  title="Features — Harvous"
  description="Harvous is a Bible study notes app — scripture pills, highlights, threads, and recall. Not a Bible reader or sermon transcription tool; built so you remember what you saved."
  jsonLd={jsonLd}
>
  <!-- Page header -->
  <section class="border-b border-[var(--color-rule)]">
    <PageIntro>
      <div class="text-xs uppercase tracking-[0.14em] text-[var(--color-ink-faint)]">Features</div>
      <h1 class="mt-3 font-display text-5xl leading-[1.0] md:text-8xl">
        Everything you need to study. Nothing you don't.
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-[var(--color-ink-soft)]">
        The same features on every device — web, iOS, iPad, and Mac.
      </p>
    </PageIntro>
  </section>

  <section class="mx-auto max-w-6xl space-y-24 px-5 py-20" data-reveal style="--reveal-delay: 80ms;">
    {items.map(({ data, Content }) => (
      <FeatureRow title={data.title} tagline={data.tagline} align={data.align}>
        <Fragment slot="body">
          <Content />
        </Fragment>
        <Fragment slot="visual">
          <!-- Decorative tile per feature. Real screenshots can be dropped in later. -->
          <div class="paper-grain aspect-[4/3] rounded-2xl"></div>
        </Fragment>
      </FeatureRow>
    ))}
  </section>

  <ComparePreview
    eyebrow="Compare"
    title="See how Harvous compares"
    lead="Harvous is notes-first — built to remember what you saved, not replace your Bible reader."
    showAllLink
  />

  <!-- Closing CTA -->
  <section class="border-t border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-24 text-center">
      <h2 class="font-display text-4xl leading-[1.05] md:text-6xl">
        Start your study Bible today.
      </h2>
      <div class="mt-8 flex justify-center">
        <CTAButton
          href="https://app.harvous.com/sign-up"
          variant="primary"
          size="lg"
          external
          fathomTrack={fathomSignup.features}
        >
          Sign up free
        </CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
