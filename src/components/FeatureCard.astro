---
/**
 * FeatureCard — a bento tile. Two variants:
 *  - soft (default): a tinted card with a label + a product screenshot (slot).
 *  - solid: a vibrant highlight-color tile with a short phrase + icon (Pangram flavor).
 * `tint` maps to the soft --tint-* tokens / the vibrant --study-dock-accent-* fills.
 * `span` controls desktop column span within <Bento> (1 or 2).
 */
import { Icon } from "astro-icon/components";
import ContentPill from "./ContentPill.astro";

interface Props {
  tint?: "sky" | "amber" | "mint" | "violet" | "coral" | "blue" | "paper";
  label?: string;
  sublabel?: string;
  href?: string;
  span?: 1 | 2;
  solid?: boolean;
  icon?: string;
  /** Brand content-type pill shown above the label (soft variant only). */
  pillType?: "note" | "scripture" | "highlight" | "folder" | "thread";
}
const { tint = "paper", label, sublabel, href, span = 1, solid = false, icon, pillType } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  class:list={["fcard", `fcard--${tint}`, solid && "fcard--solid", `fcard--span-${span}`]}
  {...href ? { href } : {}}
>
  {solid ? (
    <div class="fcard__solid">
      {icon && <span class="fcard__icon"><Icon name={icon} /></span>}
      <div class="fcard__phrase">{label}</div>
      {sublabel && <div class="fcard__sub">{sublabel}</div>}
    </div>
  ) : (
    <>
      <div class="fcard__head">
        {pillType && <div class="fcard__pill"><ContentPill type={pillType} /></div>}
        <div class="fcard__label">{label}</div>
        {sublabel && <div class="fcard__sub">{sublabel}</div>}
      </div>
      <div class="fcard__visual"><slot /></div>
    </>
  )}
</Tag>

<style>
  .fcard {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 1.5rem;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    overflow: hidden;
    color: var(--color-ink);
    text-decoration: none;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  a.fcard:hover { transform: translateY(-3px); box-shadow: var(--shadow-float); }

  /* Soft tints */
  .fcard--paper { background: var(--color-card); }
  .fcard--sky { background: var(--tint-sky); }
  .fcard--amber { background: var(--tint-amber); }
  .fcard--mint { background: var(--tint-mint); }
  .fcard--violet { background: var(--tint-violet); }
  .fcard--coral { background: var(--tint-coral); }
  .fcard--blue { background: var(--tint-blue); }

  .fcard__pill { margin-bottom: 0.85rem; }
  .fcard__label { font-weight: 600; font-size: 1.05rem; color: var(--color-ink); }
  .fcard__sub { margin-top: 0.3rem; font-size: 0.9rem; line-height: 1.5; color: var(--color-ink-soft); }
  .fcard__visual { margin-top: auto; }
  .fcard__visual :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.9rem;
    box-shadow: 0 12px 30px -14px rgba(20, 18, 12, 0.28);
  }

  /* Solid vibrant tiles — exact highlight accents */
  .fcard--solid { justify-content: center; color: #fff; min-height: 11rem; }
  .fcard--solid.fcard--sky { background: var(--study-dock-accent-skyBlue); }
  .fcard--solid.fcard--amber { background: var(--study-dock-accent-warmAmber); color: #1a1916; }
  .fcard--solid.fcard--mint { background: var(--study-dock-accent-mintGreen); color: #1a1916; }
  .fcard--solid.fcard--violet { background: var(--study-dock-accent-violet); }
  .fcard--solid.fcard--coral { background: var(--study-dock-accent-coralRose); }
  .fcard--solid.fcard--blue { background: var(--color-accent); }
  .fcard__icon { font-size: 1.5rem; line-height: 1; opacity: 0.92; }
  .fcard__phrase {
    margin-top: 0.85rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.6rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .fcard--solid .fcard__sub { margin-top: 0.5rem; color: inherit; opacity: 0.82; }

  /* Desktop column spans (within <Bento>'s 3-col grid) */
  @media (min-width: 768px) {
    .fcard--span-2 { grid-column: span 2; }
  }
</style>
