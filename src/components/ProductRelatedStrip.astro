---
import { Icon } from "astro-icon/components";
import Container from "./layout/Container.astro";
import { FEATURE_ICONS } from "../lib/feature-icons.ts";
import type { ProductPage } from "../lib/product-page-data.ts";
import type { CollectionEntry } from "astro:content";

interface Props {
  page: ProductPage;
  relatedFeatures: CollectionEntry<"features">[];
  publishedFeatureSlugs: Set<string>;
}

const { page, relatedFeatures, publishedFeatureSlugs } = Astro.props;
---

{
  relatedFeatures.length > 0 && (
    <section class="product-related frame-divider">
      <Container size="xl">
        <div class="product-related__head section-head" data-reveal>
          <span class="eyebrow-pill">Features</span>
          <h2 class="section-title">{page.relatedHeading}</h2>
          <p class="lead product-related__lead">{page.relatedLead}</p>
        </div>

        <ul class="product-related__grid" data-reveal style="--reveal-delay: 100ms;" role="list">
          {relatedFeatures.map((f) => {
            const href = publishedFeatureSlugs.has(f.id) ? `/features/${f.id}/` : undefined;
            const Tag = href ? "a" : "div";
            return (
              <li>
                <Tag
                  class:list={["product-related__card", href && "product-related__card--link"]}
                  href={href}
                >
                  <span class="product-related__icon">
                    <Icon name={FEATURE_ICONS[f.id] ?? "fa6-solid:note-sticky"} />
                  </span>
                  <span class="product-related__title">{f.data.tagline}</span>
                  <p class="product-related__desc">{f.data.title}</p>
                  {href && <span class="product-related__more">Learn more →</span>}
                </Tag>
              </li>
            );
          })}
        </ul>
      </Container>
    </section>
  )
}

<style>
  .product-related {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
  }
  .product-related__head .section-title {
    max-width: 18ch;
    margin-inline: auto;
    text-wrap: balance;
  }
  .product-related__lead {
    max-width: 38rem;
    margin-inline: auto;
    text-wrap: pretty;
  }
  .product-related__grid {
    margin-top: clamp(3rem, 7vw, 4.5rem);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1.5rem;
    list-style: none;
    padding: 0;
    margin-bottom: 0;
  }
  @media (min-width: 720px) {
    .product-related__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .product-related__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .product-related__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .product-related__card--link {
    transition: transform 200ms ease;
  }
  .product-related__card--link:hover {
    transform: translateY(-2px);
  }
  .product-related__card--link:hover .product-related__title {
    color: var(--color-accent);
  }
  .product-related__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }
  .product-related__icon :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
  }
  .product-related__title {
    display: block;
    margin-top: 0.85rem;
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--color-ink);
    transition: color 200ms ease;
  }
  .product-related__desc {
    margin-top: 0.3rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }
  .product-related__more {
    display: inline-block;
    margin-top: 0.65rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
  }
</style>
