---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "dark" | "ghost" | "white";
  size?: "md" | "lg";
  external?: boolean;
  fathomTrack?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  fathomTrack,
  class: className = "",
} = Astro.props;

const base = "inline-flex items-center justify-center gap-2 rounded-full font-medium transition-all";

const variants = {
  primary: "text-white bg-[linear-gradient(171deg,#2bb5ff_7%,#006eff_93%)] shadow-[0_1px_0_rgba(255,255,255,0.3)_inset,0_10px_24px_-10px_rgba(0,110,255,0.6)] hover:brightness-[1.05]",
  secondary: "bg-[var(--color-card)] text-[var(--color-ink)] border border-[var(--color-rule)] hover:bg-[var(--color-warm)]",
  dark: "bg-[var(--color-ink)] text-[var(--color-paper)] hover:opacity-90",
  ghost: "text-[var(--color-ink)] hover:bg-[var(--color-warm)]",
  white: "bg-white text-[#1a1916] shadow-[0_10px_24px_-10px_rgba(0,0,0,0.35)] hover:bg-white/90",
};

const sizes = {
  md: "px-4 py-2 text-sm",
  lg: "px-5 py-3 text-base",
};

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

<a
  href={href}
  class={cls}
  {...external ? { target: "_blank", rel: "noopener" } : {}}
  {...fathomTrack ? { "data-fathom-track": fathomTrack } : {}}
>
  <slot />
</a>
