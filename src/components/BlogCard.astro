---
interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: string;
  slug: string;
  readingTime?: number;
}

const { title, description, publishDate, category, slug, readingTime } = Astro.props;

const categoryLabels: Record<string, string> = {
  "study-habits": "Study habits",
  "behind-the-build": "Behind the build",
  "scripture-study": "Scripture study",
  "product": "Product",
};

const categoryColors: Record<string, { bg: string; ink: string }> = {
  "study-habits": { bg: "var(--color-mint)", ink: "var(--color-mint-ink)" },
  "behind-the-build": { bg: "var(--color-sky)", ink: "var(--color-sky-ink)" },
  "scripture-study": { bg: "var(--color-lilac)", ink: "var(--color-lilac-ink)" },
  "product": { bg: "var(--color-peach)", ink: "var(--color-peach-ink)" },
};

const label = categoryLabels[category] ?? category;
const color = categoryColors[category] ?? { bg: "var(--color-warm)", ink: "var(--color-ink-soft)" };

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(publishDate));
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col gap-4 rounded-2xl border border-[var(--color-rule)] bg-white p-6 shadow-[var(--shadow-card)] transition hover:shadow-[var(--shadow-float)] hover:-translate-y-0.5"
>
  <div class="flex items-center gap-3">
    <span
      class="rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider"
      style={`background: ${color.bg}; color: ${color.ink};`}
    >
      {label}
    </span>
    <span class="text-xs text-[var(--color-ink-faint)]">{formattedDate}</span>
    {readingTime && (
      <span class="text-xs text-[var(--color-ink-faint)]">{readingTime} min read</span>
    )}
  </div>

  <div>
    <h2 class="text-xl font-semibold leading-snug text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
      {title}
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)]">
      {description}
    </p>
  </div>

  <div class="mt-auto flex items-center gap-1 text-sm font-medium text-[var(--color-accent)]">
    Read
    <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="currentColor">
      <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/>
    </svg>
  </div>
</a>
