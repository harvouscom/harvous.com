---
import { Icon } from "astro-icon/components";
import {
  blogCategoryColor,
  blogCategoryIcon,
  blogCategoryLabel,
  blogThumbUrl,
} from "../lib/blog";

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: string;
  slug: string;
  readingTime?: number;
  draft?: boolean;
  /** Lattice-library inspired layouts */
  variant?: "featured" | "spotlight" | "story" | "card";
}

const {
  title,
  description,
  publishDate,
  category,
  slug,
  readingTime,
  draft = false,
  variant = "card",
} = Astro.props;

const label = blogCategoryLabel(category);
const color = blogCategoryColor(category);
const icon = blogCategoryIcon(category);
const featThumb = blogThumbUrl(slug, "feat");
const spotThumb = blogThumbUrl(slug, "spot");

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(publishDate));

const href = `/blog/${slug}`;
---

{
  variant === "featured" ? (
    <a
      href={href}
      class="blog-featured group block overflow-hidden rounded-[1.75rem] bg-white transition hover:bg-[color-mix(in_oklab,white_88%,var(--blog-cat))]"
      style={`--blog-cat: ${color.bg};`}
      data-blog-category={category}
    >
      <div
        class="blog-featured__art relative aspect-[16/9] w-full overflow-hidden md:aspect-[2.1/1]"
        style={`background:
          radial-gradient(80% 70% at 18% 20%, color-mix(in oklab, ${color.bg} 85%, white) 0%, transparent 55%),
          linear-gradient(145deg, color-mix(in oklab, ${color.bg} 40%, var(--color-warm)), var(--color-warm));`}
      >
        <img
          src={featThumb}
          alt=""
          width={1400}
          height={780}
          class="absolute inset-0 h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent" aria-hidden="true" />
      </div>
      <div class="grid gap-4 p-6 md:grid-cols-[1.1fr_0.9fr] md:gap-10 md:p-8 md:items-end">
        <div>
          <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--color-ink-faint)]">
            <span class="inline-flex items-center gap-1.5 font-semibold uppercase tracking-[0.12em]">
              <Icon name={icon} class="h-3 w-3" aria-hidden="true" />
              {label}
            </span>
            {draft && (
              <span class="rounded-full bg-[var(--color-ink)] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
                Draft
              </span>
            )}
          </div>
          <h2 class="mt-3 font-display text-3xl leading-[1.1] tracking-tight text-[var(--color-ink)] md:text-4xl group-hover:text-[var(--color-accent)]">
            {title}
          </h2>
        </div>
        <p class="text-sm leading-relaxed text-[var(--color-ink-soft)] md:pb-1">
          {description}
        </p>
      </div>
    </a>
  ) : variant === "spotlight" ? (
    <a
      href={href}
      class="blog-spotlight group flex items-start gap-4 rounded-2xl bg-white p-3 shadow-[var(--shadow-card)] transition duration-200 ease-out hover:-translate-y-0.5 hover:shadow-[var(--shadow-float)]"
      data-blog-category={category}
    >
      <div
        class="blog-spotlight__thumb relative h-[4.5rem] w-[4.5rem] shrink-0 overflow-hidden rounded-xl"
        style={`background: ${color.bg};`}
        aria-hidden="true"
      >
        <img
          src={spotThumb}
          alt=""
          width={360}
          height={360}
          class="absolute inset-0 h-full w-full object-cover transition duration-300 ease-out group-hover:scale-[1.06]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="min-w-0 flex flex-col justify-start pt-0.5">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-faint)]">
            <Icon name={icon} class="h-3 w-3" aria-hidden="true" />
            {label}
          </span>
          {draft && (
            <span class="rounded-full bg-[var(--color-ink)] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
              Draft
            </span>
          )}
        </div>
        <h3 class="mt-1.5 text-[0.95rem] font-semibold leading-snug text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
          {title}
        </h3>
      </div>
    </a>
  ) : variant === "story" ? (
    <a
      href={href}
      class="blog-story group flex items-start gap-4 border-b border-[var(--color-rule)] py-7 last:border-b-0 md:gap-5 md:py-8"
      data-blog-category={category}
    >
      <div
        class="blog-story__thumb relative h-[4.5rem] w-[4.5rem] shrink-0 overflow-hidden rounded-xl md:h-[5.5rem] md:w-[5.5rem]"
        style={`background: ${color.bg};`}
        aria-hidden="true"
      >
        <img
          src={spotThumb}
          alt=""
          width={360}
          height={360}
          class="absolute inset-0 h-full w-full object-cover transition duration-300 ease-out group-hover:scale-[1.06]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--color-ink-faint)]">
          {draft && (
            <span class="rounded-full bg-[var(--color-ink)] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
              Draft
            </span>
          )}
          <span>{formattedDate}</span>
          {readingTime && <span>· {readingTime} min</span>}
        </div>
        <h3 class="mt-2 font-display text-2xl leading-[1.15] tracking-tight text-[var(--color-ink)] md:mt-3 md:text-[1.65rem] group-hover:text-[var(--color-accent)]">
          {title}
        </h3>
        <p class="mt-2 max-w-2xl text-[0.95rem] leading-relaxed text-[var(--color-ink-soft)]">
          {description}
        </p>
      </div>
    </a>
  ) : (
    <a
      href={href}
      class="group flex flex-col gap-4 rounded-2xl border border-[var(--color-rule)] bg-white p-6 shadow-[var(--shadow-card)] transition hover:shadow-[var(--shadow-float)] hover:-translate-y-0.5"
      data-blog-category={category}
    >
      <div class="flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-faint)]">
          <Icon name={icon} class="h-3.5 w-3.5" aria-hidden="true" />
          {label}
        </span>
        {draft && (
          <span class="rounded-full bg-[var(--color-ink)] px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-white">
            Draft
          </span>
        )}
        <span class="text-xs text-[var(--color-ink-faint)]">{formattedDate}</span>
        {readingTime && (
          <span class="text-xs text-[var(--color-ink-faint)]">{readingTime} min read</span>
        )}
      </div>

      <div>
        <h2 class="text-xl font-semibold leading-snug text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
          {title}
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)]">
          {description}
        </p>
      </div>

      <div class="mt-auto flex items-center gap-1 text-sm font-medium text-[var(--color-accent)]">
        Read
        <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="currentColor">
          <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/>
        </svg>
      </div>
    </a>
  )
}
