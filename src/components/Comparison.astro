---
// Playful 3-way positioning: a Bible reader app vs a generic notes app vs Harvous.
import SectionCard from "./SectionCard.astro";
import { Icon } from "astro-icon/components";

const others = [
  {
    icon: "fa6-solid:book-bible",
    label: "In a Bible app",
    rows: [
      "Notes trapped verse-by-verse",
      "Highlights you never find again",
      "No room for your own connections",
    ],
  },
  {
    icon: "fa6-solid:note-sticky",
    label: "In a notes app",
    rows: [
      "Doesn't know what a verse is",
      "No scripture text, ever",
      "You organize it all by hand",
    ],
  },
];

const harvous = [
  "Scripture pills across 7 translations",
  "Highlights that collect themselves",
  "Auto-folders & tags, zero upkeep",
];
---

<SectionCard
  eyebrow="Why Harvous"
  balancedTitle
  title="Made for study, not just for reading."
  lead="Your Bible app is for reading. Your notes app doesn't know scripture. Harvous is built for the part in between — and for remembering it."
>
  <div class="cmp">
    {others.map((col) => (
      <div class="cmp-col cmp-col--other">
        <div class="cmp-col__head">
          <span class="cmp-col__icon"><Icon name={col.icon} class="h-4 w-4" /></span>
          {col.label}
        </div>
        <ul class="cmp-list">
          {col.rows.map((r) => (
            <li>
              <svg class="cmp-x" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M4 4l8 8M12 4l-8 8" />
              </svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="cmp-col cmp-col--harvous">
      <div class="cmp-col__head">
        <span class="cmp-col__icon cmp-col__icon--brand">
          <img src="/icons/app-icon.png" alt="" />
        </span>
        In Harvous
      </div>
      <ul class="cmp-list">
        {harvous.map((r) => (
          <li>
            <svg class="cmp-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8.5l3.5 3.5L13 4.5" />
            </svg>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</SectionCard>

<style>
  .cmp {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .cmp { grid-template-columns: repeat(3, 1fr); align-items: start; }
  }
  .cmp-col {
    border-radius: 1.25rem;
    padding: 1.5rem 1.4rem;
    border: 1px solid var(--color-rule);
  }
  .cmp-col--other {
    background: color-mix(in oklab, var(--color-ink) 4%, transparent);
  }
  .cmp-col--harvous {
    position: relative;
    background: linear-gradient(160deg, color-mix(in oklab, var(--color-accent) 88%, white), var(--color-accent));
    border-color: transparent;
    box-shadow: 0 18px 44px -16px color-mix(in oklab, var(--color-accent) 60%, transparent);
    color: #fff;
  }
  @media (min-width: 768px) {
    .cmp-col--harvous { transform: translateY(-0.75rem) scale(1.02); }
  }
  .cmp-col__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 1.1rem;
  }
  .cmp-col--other .cmp-col__head { color: var(--color-ink-soft); }
  .cmp-col__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.6rem;
    background: color-mix(in oklab, var(--color-ink) 7%, transparent);
    color: var(--color-ink-faint);
  }
  .cmp-col__icon--brand {
    background: transparent;
    overflow: hidden;
  }
  .cmp-col__icon--brand img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .cmp-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .cmp-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .cmp-col--other .cmp-list li { color: var(--color-ink-soft); }
  .cmp-col--harvous .cmp-col__head { color: #fff; }
  .cmp-col--harvous .cmp-list li { color: rgba(255, 255, 255, 0.92); font-weight: 500; }
  .cmp-x {
    flex: none;
    width: 1rem;
    height: 1rem;
    margin-top: 0.1rem;
    color: var(--color-ink-faint);
  }
  .cmp-check {
    flex: none;
    width: 1rem;
    height: 1rem;
    margin-top: 0.1rem;
    color: #fff;
  }
</style>
