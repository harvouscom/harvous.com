---
/**
 * Compact end-of-post author close + share actions for Bright Enough.
 */
import { Icon } from "astro-icon/components";
import type { BlogAuthor } from "../lib/blog";

interface Props {
  author: BlogAuthor;
  title: string;
  url: string;
  description?: string;
}

const { author, title, url, description = "" } = Astro.props;
const initials = author.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .join("");

const mailtoHref = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(
  `${title}\n\n${description ? `${description}\n\n` : ""}${url}`,
)}`;
---

<footer
  class="blog-author-close"
  data-blog-share
  data-share-title={title}
  data-share-text={description}
  data-share-url={url}
>
  <div class="blog-author-close__who">
    {
      author.avatar ? (
        <img
          src={author.avatar}
          alt=""
          width={36}
          height={36}
          class="blog-author-close__avatar"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="blog-author-close__initials" aria-hidden="true">
          {initials || "BE"}
        </span>
      )
    }
    <div class="blog-author-close__text">
      {
        author.href ? (
          <a href={author.href} class="blog-author-close__name">
            {author.name}
          </a>
        ) : (
          <span class="blog-author-close__name">{author.name}</span>
        )
      }
      <p class="blog-author-close__role">{author.role}</p>
      {
        author.email && author.kind === "team" && (
          <a href={`mailto:${author.email}`} class="blog-author-close__email">
            {author.email}
          </a>
        )
      }
    </div>
  </div>

  <div class="blog-author-close__share" role="group" aria-label="Share this article">
    <button type="button" class="blog-share-btn" data-blog-share-copy>
      <Icon name="fa6-solid:link" aria-hidden="true" />
      <span data-blog-share-copy-label>Copy link</span>
    </button>

    <button type="button" class="blog-share-btn" data-blog-share-native hidden>
      <Icon name="fa6-solid:share-nodes" aria-hidden="true" />
      <span>Share</span>
    </button>

    <a class="blog-share-btn" href={mailtoHref}>
      <Icon name="fa6-solid:envelope" aria-hidden="true" />
      <span>Email</span>
    </a>
  </div>
</footer>

<style>
  .blog-author-close {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem 1.25rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .blog-author-close__who {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .blog-author-close__avatar,
  .blog-author-close__initials {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    object-fit: cover;
  }

  .blog-author-close__initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in oklab, var(--color-warm) 70%, white);
    color: var(--color-ink-soft);
    font-size: 0.6875rem;
    font-weight: 650;
    letter-spacing: 0.04em;
  }

  .blog-author-close__text {
    min-width: 0;
  }

  .blog-author-close__name {
    display: block;
    font-size: 0.9375rem;
    font-weight: 650;
    line-height: 1.2;
    color: var(--color-ink);
    text-decoration: none;
  }

  a.blog-author-close__name:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-author-close__role {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.25;
    color: var(--color-ink-faint);
  }

  .blog-author-close__email {
    display: inline-block;
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: var(--color-ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-rule);
  }

  .blog-author-close__email:hover {
    text-decoration-color: var(--color-ink);
  }

  .blog-author-close__share {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .blog-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--color-rule);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-ink-soft);
    font: inherit;
    font-size: 0.75rem;
    font-weight: 550;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background-color 140ms ease;
  }

  .blog-share-btn :global(svg) {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .blog-share-btn:hover {
    color: var(--color-ink);
    border-color: color-mix(in oklab, var(--color-ink) 22%, var(--color-rule));
    background: color-mix(in oklab, var(--color-warm) 45%, white);
  }

  .blog-share-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .blog-share-btn.is-copied {
    color: var(--color-ink);
    border-color: color-mix(in oklab, var(--color-ink) 28%, var(--color-rule));
    background: color-mix(in oklab, var(--color-warm) 70%, white);
  }
</style>

<script>
  function initBlogShare(root: HTMLElement) {
    const title = root.dataset.shareTitle || document.title;
    const text = root.dataset.shareText || "";
    const url = root.dataset.shareUrl || window.location.href;

    const copyBtn = root.querySelector<HTMLButtonElement>("[data-blog-share-copy]");
    const copyLabel = root.querySelector<HTMLElement>("[data-blog-share-copy-label]");
    const nativeBtn = root.querySelector<HTMLButtonElement>("[data-blog-share-native]");

    if (nativeBtn && typeof navigator.share === "function") {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener("click", async () => {
        try {
          await navigator.share({ title, text, url });
        } catch {
          /* user cancelled or share failed — ignore */
        }
      });
    }

    if (!copyBtn || !copyLabel) return;

    let resetTimer: ReturnType<typeof setTimeout> | null = null;
    const setCopied = (copied: boolean) => {
      copyBtn.classList.toggle("is-copied", copied);
      copyLabel.textContent = copied ? "Copied" : "Copy link";
      copyBtn.setAttribute(
        "aria-label",
        copied ? "Link copied" : "Copy link to this article",
      );
    };

    copyBtn.setAttribute("aria-label", "Copy link to this article");
    copyBtn.addEventListener("click", async () => {
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(url);
        } else {
          const ta = document.createElement("textarea");
          ta.value = url;
          ta.setAttribute("readonly", "");
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
        }
        setCopied(true);
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(() => setCopied(false), 1800);
      } catch {
        setCopied(false);
      }
    });
  }

  document.querySelectorAll<HTMLElement>("[data-blog-share]").forEach(initBlogShare);
</script>
