---
/**
 * UseCasesPreview — homepage carousel of the same five use cases defined on
 * /use-cases (icon, tone, title, one-line description). Mirrors the data in
 * use-cases/index.astro.
 *
 * Styled after Mintlify's customer-stories carousel: a left-aligned header
 * (eyebrow + title + lead) with prev/next arrow controls, then a horizontal
 * scroll-snap row of cards that bleeds past the framed column to the viewport
 * edge so the next card visibly peeks in.
 */
import { Icon } from "astro-icon/components";
import Container from "./layout/Container.astro";
import { getUseCases, getUseCaseDisplayTitle } from "../lib/use-cases-data.ts";

const useCases = getUseCases();
---

<section class="usecases frame-divider" id="use-cases">
  <Container size="xl">
    <div class="usecases__head" data-reveal>
      <div class="usecases__head-text">
        <span class="eyebrow-pill">Use cases</span>
        <h2 class="section-title">Harvous is for people who actually study.</h2>
        <p class="lead">Not a Bible reader. Not a devotional. A place for your notes, your questions, and everything you want to hold onto.</p>
      </div>

      <div class="usecases__controls">
        <button type="button" class="usecases__arrow" data-dir="prev" aria-label="Previous use case" disabled>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 3L5 8l5 5"/>
          </svg>
        </button>
        <button type="button" class="usecases__arrow" data-dir="next" aria-label="Next use case">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 3l5 5-5 5"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="usecases__track-wrap" data-reveal style="--reveal-delay: 80ms;">
      <ul class="usecases__track" role="list" aria-label="Use cases" tabindex="0">
        {useCases.map((uc) => {
          const title = getUseCaseDisplayTitle(uc);
          const caption = (
            <span class="usecases__caption">
              <strong>{title}.</strong> {uc.tagline}
              {!uc.comingSoon && (
                <span class="usecases__link"> See how it works →</span>
              )}
            </span>
          );
          return (
            <li class="usecases__slide">
              {uc.comingSoon ? (
                <article class="usecases__card usecases__card--soon">
                  <span
                    class="usecases__art"
                    style={`--usecase-art-image: url('${uc.image}');`}
                  >
                    <span class="usecases__soon">Coming soon</span>
                    <span class="usecases__badge">
                      <Icon name={uc.icon} style={`color: ${uc.ink};`} />
                    </span>
                  </span>
                  {caption}
                </article>
              ) : (
                <a href={uc.href} class="usecases__card usecases__card--link">
                  <span
                    class="usecases__art"
                    style={`--usecase-art-image: url('${uc.image}');`}
                  >
                    <span class="usecases__badge">
                      <Icon name={uc.icon} style={`color: ${uc.ink};`} />
                    </span>
                  </span>
                  {caption}
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </Container>
</section>

<style>
  .usecases {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .usecases__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 2rem;
  }
  .usecases__head-text {
    max-width: 34rem;
  }
  .usecases__head-text > * + * {
    margin-top: 0.85rem;
  }
  .usecases__controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
  }

  .usecases__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    flex: none;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    background: var(--color-card);
    color: var(--color-ink-soft);
    transition: color 150ms ease, background-color 150ms ease, opacity 150ms ease;
  }
  .usecases__arrow svg {
    width: 0.8rem;
    height: 0.8rem;
  }
  .usecases__arrow:hover:not(:disabled) {
    color: var(--color-ink);
    background: var(--color-warm);
  }
  .usecases__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .usecases__track-wrap {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    margin-top: clamp(2.25rem, 5vw, 3.25rem);
  }

  .usecases__track {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding-block: 0.25rem;
    padding-left: max(var(--frame-content-pad), calc((100vw - 72rem) / 2 + var(--frame-content-pad)));
    padding-right: var(--frame-gutter);
    scroll-padding-left: max(var(--frame-content-pad), calc((100vw - 72rem) / 2 + var(--frame-content-pad)));
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .usecases__track::-webkit-scrollbar {
    display: none;
  }
  .usecases__track:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .usecases__slide {
    flex: none;
    width: clamp(16rem, 70vw, 18.5rem);
    scroll-snap-align: start;
  }

  .usecases__card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
  }
  .usecases__card--link {
    color: inherit;
    text-decoration: none;
    border-radius: 0.25rem;
    transition: transform 0.15s ease;
  }
  .usecases__card--link:hover {
    transform: translateY(-2px);
  }
  .usecases__card--link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }
  .usecases__link {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .usecases__art {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1.05;
    border-radius: 1.25rem;
    overflow: hidden;
    background-color: var(--color-warm);
    background-image: var(--usecase-art-image);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .usecases__art::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-paper) 10%, transparent) 0%,
      color-mix(in oklab, var(--color-ink) 5%, transparent) 100%
    );
    pointer-events: none;
  }
  .usecases__soon {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 1;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    color: var(--color-ink-faint);
    background: color-mix(in oklab, var(--color-card) 88%, transparent);
    border: 1px solid var(--color-rule);
    backdrop-filter: blur(6px);
  }
  .usecases__badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.25rem;
    height: 4.25rem;
    border-radius: 1rem;
    background: var(--color-card);
    box-shadow: var(--shadow-card);
  }
  .usecases__badge :global(svg) {
    width: 1.65rem;
    height: 1.65rem;
  }

  .usecases__caption {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .usecases__caption strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .usecases__arrow {
      display: none;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>(".usecases");
  const track = root?.querySelector<HTMLElement>(".usecases__track");
  if (root && track) {
    const prevBtn = root.querySelector<HTMLButtonElement>('.usecases__arrow[data-dir="prev"]');
    const nextBtn = root.querySelector<HTMLButtonElement>('.usecases__arrow[data-dir="next"]');
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const updateArrows = () => {
      const max = track.scrollWidth - track.clientWidth - 1;
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 0;
      if (nextBtn) nextBtn.disabled = track.scrollLeft >= max;
    };

    const step = () => {
      const slide = track.querySelector<HTMLElement>(".usecases__slide");
      if (!slide) return track.clientWidth * 0.9;
      const gap = parseFloat(getComputedStyle(track).columnGap || "0") || 0;
      return slide.getBoundingClientRect().width + gap;
    };

    const scrollByDir = (dir: 1 | -1) => {
      track.scrollBy({ left: dir * step(), behavior: reduced ? "auto" : "smooth" });
    };

    prevBtn?.addEventListener("click", () => scrollByDir(-1));
    nextBtn?.addEventListener("click", () => scrollByDir(1));

    let ticking = false;
    track.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          updateArrows();
          ticking = false;
        });
      },
      { passive: true }
    );

    window.addEventListener("resize", updateArrows);
    updateArrows();
  }
</script>
