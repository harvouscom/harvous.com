---
import Container from "./layout/Container.astro";
import type { CompareEntry } from "../lib/compare-data.ts";
import { fathomCompare } from "../lib/fathom-events.ts";

interface Props {
  entries: CompareEntry[];
  groupTitle?: string;
  groupTitleId?: string;
  trackLabel: string;
  fathomTrack?: string;
  /** When false, only the scroll track renders (parent supplies its own control bar). */
  showBar?: boolean;
  class?: string;
}

const {
  entries,
  groupTitle,
  groupTitleId,
  trackLabel,
  fathomTrack = fathomCompare.hubCard,
  showBar = true,
  class: className = "",
} = Astro.props;
---

<div class:list={["compare-carousel", className]}>
  {
    showBar && (
      <Container size="xl">
        <div class="compare-carousel__bar">
          {groupTitle ? (
            <h2 class="compare-carousel__title" id={groupTitleId}>
              {groupTitle}
            </h2>
          ) : (
            <span class="compare-carousel__bar-spacer" aria-hidden="true" />
          )}
          <div class="compare-carousel__controls">
            <button type="button" class="compare-carousel__arrow" data-dir="prev" aria-label="Previous comparison" disabled>
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10 3L5 8l5 5"/>
              </svg>
            </button>
            <button type="button" class="compare-carousel__arrow" data-dir="next" aria-label="Next comparison">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 3l5 5-5 5"/>
              </svg>
            </button>
          </div>
        </div>
      </Container>
    )
  }

  <div class="compare-carousel__track-wrap">
    <ul
      class="compare-carousel__track"
      role="list"
      aria-label={trackLabel}
      tabindex="0"
      style={`--carousel-cols: ${entries.length};`}
    >
      {
        entries.map((entry) => (
          <li class="compare-carousel__slide">
            <a class="compare-carousel__card" href={`/compare/${entry.slug}/`} data-fathom-track={fathomTrack}>
              <span class="compare-carousel__art">
                <span class="compare-carousel__icon-wrap">
                  <img
                    class="compare-carousel__icon"
                    src={entry.competitorImage}
                    alt=""
                    width="72"
                    height="72"
                    loading="lazy"
                  />
                </span>
              </span>
              <span class="compare-carousel__caption">
                <strong>Harvous vs {entry.name}.</strong> {entry.intro}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .compare-carousel__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.5rem;
  }
  .compare-carousel__bar-spacer {
    flex: 1;
  }
  .compare-carousel__title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .compare-carousel__controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
    margin-left: auto;
  }

  .compare-carousel__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    flex: none;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    background: var(--color-card);
    color: var(--color-ink-soft);
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease, opacity 150ms ease;
  }
  .compare-carousel__arrow svg {
    width: 0.8rem;
    height: 0.8rem;
  }
  .compare-carousel__arrow:hover:not(:disabled) {
    color: var(--color-ink);
    background: var(--color-warm);
  }
  .compare-carousel__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .compare-carousel__track-wrap {
    position: relative;
    overflow: hidden;
    margin-inline: var(--frame-inset);
    margin-top: clamp(1rem, 2.5vw, 1.35rem);
  }
  .compare-carousel--tight .compare-carousel__track-wrap {
    margin-top: clamp(2.25rem, 5vw, 3.25rem);
  }

  .compare-carousel__track {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding-block: 0.25rem;
    padding-left: max(
      var(--frame-inset),
      calc((100vw - 72rem) / 2 + var(--frame-content-pad) - var(--frame-inset))
    );
    padding-right: var(--frame-inset);
    scroll-padding-left: max(
      var(--frame-inset),
      calc((100vw - 72rem) / 2 + var(--frame-content-pad) - var(--frame-inset))
    );
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .compare-carousel__track::-webkit-scrollbar {
    display: none;
  }
  .compare-carousel__track:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .compare-carousel__slide {
    flex: none;
    width: clamp(16rem, 70vw, 18.5rem);
    scroll-snap-align: start;
  }

  .compare-carousel__card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .compare-carousel__art {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1.05;
    border-radius: 1.25rem;
    overflow: hidden;
    background: linear-gradient(
      165deg,
      color-mix(in oklab, var(--color-warm) 88%, var(--color-card)) 0%,
      color-mix(in oklab, var(--color-ink) 4%, var(--color-warm)) 100%
    );
    border: 1px solid var(--color-rule);
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .compare-carousel__card:hover .compare-carousel__art {
    border-color: color-mix(in srgb, var(--color-ink) 14%, var(--color-rule));
    background: color-mix(in oklab, var(--color-warm) 70%, var(--color-card));
  }

  .compare-carousel__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 1.25rem;
    background: var(--color-card);
    box-shadow: var(--shadow-card);
  }

  .compare-carousel__icon {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 1rem;
    object-fit: cover;
  }

  .compare-carousel__caption {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .compare-carousel__caption strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .compare-carousel__controls {
      display: none;
    }
  }
</style>

<script>
  import { bindCarouselFit } from "../lib/carousel-fit.ts";

  document.querySelectorAll<HTMLElement>(".compare-carousel").forEach((root) => {
    const track = root.querySelector<HTMLElement>(".compare-carousel__track");
    if (!track) return;

    bindCarouselFit({
      fitRoots: [root],
      track,
      slideSelector: ".compare-carousel__slide",
      controlRoots: Array.from(root.querySelectorAll<HTMLElement>(".compare-carousel__controls")),
      prevBtn: root.querySelector<HTMLButtonElement>('.compare-carousel__arrow[data-dir="prev"]'),
      nextBtn: root.querySelector<HTMLButtonElement>('.compare-carousel__arrow[data-dir="next"]'),
    });
  });
</script>
