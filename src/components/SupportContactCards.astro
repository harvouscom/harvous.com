---
const APP_SUPPORT_URL = "https://app.harvous.com/settings/support";
const STATUS_URL = "https://status.harvous.com";
const SUPPORT_EMAIL = "derek@harvous.com";
const mailtoHref = `mailto:${SUPPORT_EMAIL}?subject=${encodeURIComponent("Harvous support")}`;

interface Props {
  /** Tighter spacing for FAQ accordion answers. */
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={["support-contact", { "support-contact--compact": compact }]}>
  <div class="support-contact__grid">
    <article class="support-contact-card support-contact-card--email">
      <span class="support-contact-card__label">Email</span>
      <a href={mailtoHref} class="support-contact-card__title">{SUPPORT_EMAIL}</a>
      <p class="support-contact-card__detail">
        Best for account questions, billing, or anything you prefer to send from your mail app.
      </p>
      <button
        type="button"
        class="btn-pill support-contact-card__copy"
        data-copy-email={SUPPORT_EMAIL}
        aria-label="Copy email address"
      >
        <svg class="support-contact-card__copy-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="5.5" y="5.5" width="8" height="8" rx="1.2"/>
          <path d="M10.5 5.5V4.8a1.3 1.3 0 0 0-1.3-1.3H3.8a1.3 1.3 0 0 0-1.3 1.3v5.4a1.3 1.3 0 0 0 1.3 1.3h.7"/>
        </svg>
        <svg class="support-contact-card__copy-icon support-contact-card__copy-icon--check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3.5 8.5l3 3 6-6"/>
        </svg>
        <span class="support-contact-card__copy-label">Copy email</span>
      </button>
    </article>

    <article class="support-contact-card">
      <span class="support-contact-card__label">In the app</span>
      <a href={APP_SUPPORT_URL} class="support-contact-card__title">Settings → Support</a>
      <p class="support-contact-card__detail">
        Signed-in users can send bug reports, ideas, and questions with app version and device context attached.
      </p>
      <span class="support-contact-card__meta">Opens app.harvous.com</span>
    </article>
  </div>

  <div class="support-contact__status">
    For service status, see
    <a href={STATUS_URL} target="_blank" rel="noopener noreferrer">status.harvous.com</a>.
  </div>
</div>

<script>
  const copyButtons = document.querySelectorAll<HTMLButtonElement>("[data-copy-email]");

  for (const button of copyButtons) {
    if (button.dataset.copyBound === "true") continue;
    button.dataset.copyBound = "true";

    button.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const email = button.dataset.copyEmail;
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
        button.classList.add("is-copied");
        button.setAttribute("aria-label", "Copied email address");
        const label = button.querySelector(".support-contact-card__copy-label");
        if (label) label.textContent = "Copied";

        window.setTimeout(() => {
          button.classList.remove("is-copied");
          button.setAttribute("aria-label", "Copy email address");
          if (label) label.textContent = "Copy email";
        }, 2000);
      } catch {
        button.setAttribute("aria-label", "Could not copy email address");
      }
    });
  }
</script>

<style>
  .support-contact {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .support-contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) {
    .support-contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .support-contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.15rem 1.2rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-rule);
    background-color: var(--color-paper);
    text-decoration: none;
    color: inherit;
    transition: background-color 150ms ease, transform 150ms ease, border-color 150ms ease;
  }
  .support-contact-card:hover {
    text-decoration: none;
    background-color: var(--color-warm);
    border-color: color-mix(in srgb, var(--color-ink) 10%, var(--color-rule));
    transform: translateY(-1px);
  }

  .support-contact-card__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .support-contact-card__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    text-decoration-line: none;
  }
  .support-contact-card__title:hover,
  .support-contact-card__title:focus-visible {
    text-decoration: none;
    text-decoration-line: none;
  }

  .support-contact-card__copy {
    width: 100%;
    margin-top: auto;
  }
  .support-contact-card__copy-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex: none;
  }
  .support-contact-card__copy-icon--check {
    display: none;
  }
  .support-contact-card__copy.is-copied .support-contact-card__copy-icon:not(.support-contact-card__copy-icon--check) {
    display: none;
  }
  .support-contact-card__copy.is-copied .support-contact-card__copy-icon--check {
    display: block;
    color: #047857;
  }
  .support-contact-card__copy.is-copied {
    color: #047857;
  }

  .support-contact-card__detail {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  .support-contact-card__meta {
    margin-top: auto;
    padding-top: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-ink-faint);
  }

  .support-contact__status {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  .support-contact__status a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .support-contact__status a:hover {
    text-decoration: underline;
  }

  .support-contact--compact .support-contact-card {
    padding: 1rem 1.05rem 1.1rem;
  }
  .support-contact--compact .support-contact-card__title {
    font-size: 0.98rem;
  }
  .support-contact--compact .support-contact-card__detail {
    font-size: 0.8125rem;
  }
</style>
