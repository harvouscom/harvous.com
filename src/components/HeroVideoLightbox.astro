---
interface Props {
  src: string;
  label?: string;
}

const { src, label = "Watch the tour" } = Astro.props;
---

<div class="hero-video" data-hero-video-root>
  <button
    type="button"
    class="hero-video-callout"
    aria-label={`${label} — opens video in a lightbox`}
    data-hero-video-trigger
  >
  <span class="hero-video-callout__play" aria-hidden="true">
    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
      <path d="M4.5 2.8v10.4c0 .6.7 1 1.2.7l8.2-5.2c.5-.3.5-1 0-1.3L5.7 2.1c-.5-.3-1.2.1-1.2.7z"></path>
    </svg>
  </span>
  <span class="hero-video-callout__label">{label}</span>
</button>

  <div
    class="hero-video-lightbox"
    role="dialog"
    aria-modal="true"
    aria-label={label}
    hidden
    data-hero-video-lightbox
  >
    <div class="hero-video-lightbox__backdrop" data-hero-video-close></div>
  <div class="hero-video-lightbox__panel">
    <button type="button" class="hero-video-lightbox__close" data-hero-video-close aria-label="Close video">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M4 4l8 8M12 4l-8 8" stroke-linecap="round"></path>
      </svg>
    </button>
    <video class="hero-video-lightbox__video" controls playsinline preload="metadata" data-hero-video-player>
      <source src={src} type="video/mp4" />
    </video>
  </div>
</div>
</div>

<style>
  .hero-video {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .hero-video-callout {
    position: absolute;
    bottom: clamp(1rem, 3vw, 1.75rem);
    left: clamp(1rem, 3vw, 1.75rem);
    z-index: 2;
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.375rem 0.875rem 0.375rem 0.375rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, #fff 35%, transparent);
    background: color-mix(in srgb, var(--color-ink) 58%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    transition: background-color 150ms ease, border-color 150ms ease;
  }
  .hero-video-callout:hover {
    background: color-mix(in srgb, var(--color-ink) 68%, transparent);
    border-color: color-mix(in srgb, #fff 45%, transparent);
  }
  .hero-video-callout:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .hero-video-callout__play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(171deg, #2bb5ff 7%, #006eff 93%);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.25) inset;
  }
  .hero-video-callout__play svg {
    margin-left: 0.1em;
  }

  .hero-video-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding: clamp(1rem, 4vw, 2rem);
  }
  .hero-video-lightbox[hidden] {
    display: none;
  }

  .hero-video-lightbox__backdrop {
    position: fixed;
    inset: 0;
    border: none;
    padding: 0;
    margin: 0;
    background: color-mix(in srgb, var(--color-ink) 72%, transparent);
    cursor: pointer;
  }

  .hero-video-lightbox__panel {
    position: relative;
    z-index: 1;
    width: min(960px, 100%);
    max-height: min(85dvh, 720px);
    border-radius: clamp(12px, 2vw, var(--radius-card));
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: var(--color-ink);
    box-shadow: var(--shadow-float);
  }

  .hero-video-lightbox__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid color-mix(in srgb, #fff 22%, transparent);
    border-radius: 50%;
    padding: 0;
    color: #fff;
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .hero-video-lightbox__close:hover {
    background: color-mix(in srgb, var(--color-ink) 75%, transparent);
  }
  .hero-video-lightbox__close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .hero-video-lightbox__close svg {
    width: 1rem;
    height: 1rem;
  }

  .hero-video-lightbox__video {
    display: block;
    width: 100%;
    max-width: 100%;
    max-height: min(85dvh, 720px);
    height: auto;
    vertical-align: middle;
    object-fit: contain;
    background: #000;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video-callout,
    .hero-video-lightbox__close {
      transition: none;
    }
  }
</style>

<script>
  function initHeroVideoLightbox(root: HTMLElement) {
    const trigger = root.querySelector<HTMLButtonElement>("[data-hero-video-trigger]");
    const lightbox = root.querySelector<HTMLElement>("[data-hero-video-lightbox]");
    const video = root.querySelector<HTMLVideoElement>("[data-hero-video-player]");
    const closeEls = root.querySelectorAll<HTMLElement>("[data-hero-video-close]");
    const closeBtn = root.querySelector<HTMLButtonElement>(".hero-video-lightbox__close");

    if (!trigger || !lightbox || !video || !closeBtn) return;

    // Escape .hero__shot-frame overflow/transform so fixed backdrop covers the viewport.
    if (lightbox.parentElement !== document.body) {
      document.body.appendChild(lightbox);
    }

    let previousFocus: HTMLElement | null = null;

    const getFocusables = () =>
      Array.from(
        lightbox.querySelectorAll<HTMLElement>(
          'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), video[controls], [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute("hidden") && el.offsetParent !== null);

    const trapFocus = (event: KeyboardEvent) => {
      if (event.key !== "Tab" || lightbox.hidden) return;
      const focusables = getFocusables();
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    const open = () => {
      previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
      closeBtn.focus();
      void video.play().catch(() => {});
    };

    const close = () => {
      lightbox.hidden = true;
      document.body.style.overflow = "";
      video.pause();
      previousFocus?.focus();
      previousFocus = null;
    };

    trigger.addEventListener("click", open);
    closeEls.forEach((el) => el.addEventListener("click", close));
    lightbox.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        event.preventDefault();
        close();
        return;
      }
      trapFocus(event);
    });
  }

  document.querySelectorAll<HTMLElement>("[data-hero-video-root]").forEach(initHeroVideoLightbox);
</script>
