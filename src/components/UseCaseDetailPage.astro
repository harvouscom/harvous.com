---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageClosingCTA from "./PageClosingCTA.astro";
import RelatedBlogPosts from "./RelatedBlogPosts.astro";
import UseCaseRelatedFeatures from "./UseCaseRelatedFeatures.astro";
import ComparePreview from "./ComparePreview.astro";
import { Icon } from "astro-icon/components";
import { getCollection, getEntry, render } from "astro:content";
import { getCompareBySlug } from "../lib/compare-data.ts";
import type { UseCase } from "../lib/use-cases-data.ts";
import { getUseCaseBySlug, getUseCaseDisplayTitle } from "../lib/use-cases-data.ts";
import { getComingSoonGridItem } from "../lib/coming-soon-grid.ts";
import type { RelatedFeatureCard } from "../lib/coming-soon-grid.ts";
import { getAudiencesForUseCase } from "../lib/for-audiences-data.ts";
import {
  getRelatedBlogPosts,
  includeBlogDrafts,
  isBlogPostListed,
} from "../lib/blog.ts";
import { fathomSignup, fathomCompare } from "../lib/fathom-events.ts";
import { buildSignupUrl } from "../lib/signup-url.ts";
import { inlineMdLinksToHtml } from "../lib/inline-md-links.ts";
import "../styles/use-cases.css";

interface Props {
  useCase: UseCase;
}

const { useCase } = Astro.props;

const allFeatures = await getCollection("features");
const relatedFeatureCards: RelatedFeatureCard[] = useCase.featureIds
  .map((id) => {
    const soon = getComingSoonGridItem(id);
    if (soon) return { kind: "comingSoon" as const, item: soon };
    const feature = allFeatures.find((f) => f.id === id);
    return feature ? { kind: "feature" as const, feature } : undefined;
  })
  .filter((c): c is RelatedFeatureCard => c !== undefined);

const relatedCompare = useCase.compareSlugs
  .map((slug) => getCompareBySlug(slug))
  .filter((e): e is NonNullable<typeof e> => e !== undefined);

const relatedAudiences = getAudiencesForUseCase(useCase.slug);

const relatedUseCases = (useCase.relatedUseCaseSlugs ?? [])
  .map((slug) => getUseCaseBySlug(slug))
  .filter((uc): uc is UseCase => uc !== undefined);

const showDrafts = includeBlogDrafts();
const relatedBlogPosts = getRelatedBlogPosts(
  (await getCollection("blog")).filter((p) => isBlogPostListed(p, showDrafts)),
  { useCase: useCase.slug },
);

const testimonialEntry = useCase.testimonialId
  ? await getEntry("testimonials", useCase.testimonialId)
  : undefined;
const testimonialRender = testimonialEntry ? await render(testimonialEntry) : undefined;

const pageUrl = `https://harvous.com${useCase.href}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: useCase.seoTitle,
      description: useCase.seoDescription,
      url: pageUrl,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Harvous", item: "https://harvous.com/" },
        { "@type": "ListItem", position: 2, name: "Use cases", item: "https://harvous.com/use-cases/" },
        { "@type": "ListItem", position: 3, name: useCase.title, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout title={useCase.seoTitle} description={useCase.seoDescription} jsonLd={jsonLd}>
  <article class="use-case-detail" style={`--use-case-ink: ${useCase.ink};`}>
    <!-- Hero -->
    <header class="border-b border-[var(--color-rule)]">
      <div class="detail-content py-10 md:py-14">
        <div data-reveal>
          <div class="use-case-detail__nav">
          <a href="/use-cases/" class="btn-pill inline-flex items-center gap-1.5 text-sm">
            <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M14 8a.75.75 0 0 1-.75.75H3.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L3.56 7.25H13.25A.75.75 0 0 1 14 8Z"
                clip-rule="evenodd"></path>
            </svg>
            Use cases
          </a>
        </div>

        <div
          class="use-case-hero__art mt-8"
          style={`--usecase-art-image: url('${useCase.image}');`}
        >
          <span class="use-case-hero__badge">
            <Icon name={useCase.icon} style={`color: ${useCase.ink};`} />
          </span>
        </div>

        <div class="mt-8 text-center">
          <div class="use-case-detail__badges">
            <span
              class="use-case-detail__title-badge"
              style={`background: color-mix(in oklab, ${useCase.ink} 14%, var(--color-paper)); color: ${useCase.ink};`}
            >
              {useCase.title}
            </span>
            {useCase.comingSoon && (
              <span class="use-case-detail__soon-badge">
                {useCase.comingSoonLine ?? "Coming soon"}
              </span>
            )}
          </div>
          <h1 class="mt-5 font-display text-4xl leading-[1.05] md:text-5xl">{useCase.heroTitle}</h1>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)]">
            {useCase.heroLead}
          </p>
        </div>
        </div>
      </div>
    </header>

    <!-- Prose body -->
    <section class="detail-content py-14 md:py-16" data-reveal style="--reveal-delay: 80ms;">
      <div class="prose-letter space-y-8">
        {
          useCase.sections.map((section) => (
            <div>
              <h2 class="text-xl font-semibold text-[var(--color-ink)]">{section.heading}</h2>
              {section.paragraphs.map((p) => (
                <p class="mt-3 text-[var(--color-ink-soft)]" set:html={inlineMdLinksToHtml(p)} />
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Feature moments -->
    <section class="frame-divider">
      <div class="detail-content py-14 md:py-16">
        <h2 class="font-display text-2xl leading-snug md:text-3xl">What that looks like in Harvous</h2>
        <ul class="mt-8 grid gap-8 sm:grid-cols-2" data-reveal="stagger" role="list">
          {
            useCase.moments.map((m) => (
              <li class="flex gap-4">
                <span class="use-case-moment__icon">
                  <Icon name={m.icon} />
                </span>
                <div>
                  <h3 class="font-semibold text-[var(--color-ink)]">{m.heading}</h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-ink-soft)]">{m.body}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {
      relatedUseCases.length > 0 && (
        <section class="frame-divider">
          <div class="detail-content py-14 md:py-16">
            <h2 class="font-display text-2xl leading-snug md:text-3xl">Related ways to study</h2>
            <p class="mt-3 text-[var(--color-ink-soft)]">
              Same notes-first tools — a clearer page when your rhythm has a name.
            </p>
            <ul class="use-case-audiences" data-reveal="stagger" role="list">
              {relatedUseCases.map((uc) => (
                <li>
                  <a href={uc.href} class="use-case-audiences__pill">
                    <Icon name={uc.icon} />
                    <span>{getUseCaseDisplayTitle(uc)}</span>
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-5">
              <a href="/use-cases/" class="text-sm font-medium text-[var(--color-accent)] hover:underline">
                See all use cases →
              </a>
            </p>
          </div>
        </section>
      )
    }

    {
      relatedAudiences.length > 0 && (
        <section class="frame-divider">
          <div class="detail-content py-14 md:py-16">
            <h2 class="font-display text-2xl leading-snug md:text-3xl">Harvous is for…</h2>
            <p class="mt-3 text-[var(--color-ink-soft)]">
              Same way of studying — different people who show up that way. Pick the one that sounds like you.
            </p>
            <ul class="use-case-audiences" data-reveal="stagger" role="list">
              {relatedAudiences.map((audience) => (
                <li>
                  <a href={audience.href} class="use-case-audiences__pill">
                    <Icon name={audience.icon} />
                    <span>{audience.title}</span>
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-5">
              <a href="/for/" class="text-sm font-medium text-[var(--color-accent)] hover:underline">
                See everyone Harvous is for →
              </a>
            </p>
          </div>
        </section>
      )
    }

    <UseCaseRelatedFeatures
      featuresHeading={useCase.featuresHeading}
      featuresLead={useCase.featuresLead}
      cards={relatedFeatureCards}
    />

    {
      relatedCompare.length > 0 && (
        <ComparePreview
          id="works-alongside"
          entries={relatedCompare}
          eyebrow="Compare"
          title="Works alongside other tools"
          lead="Harvous does a different job than most Bible apps. Many people use it next to something they already love."
          showAllLink
          fathomTrack={fathomCompare.detailRelated}
          fathomAllTrack={fathomCompare.homeAll}
        />
      )
    }

    <!-- Testimonial -->
    {
      testimonialRender && testimonialEntry && (
        <section class="fade-rule-t">
          <div class="detail-content max-w-2xl py-16 text-center use-case-testimonial">
            <blockquote class="use-case-testimonial__quote font-display text-3xl leading-snug md:text-4xl">
              <testimonialRender.Content />
            </blockquote>
            <figcaption class="mt-6 text-sm italic text-[var(--color-ink-soft)]">
              &mdash;{testimonialEntry.data.name}, {testimonialEntry.data.when}
            </figcaption>
          </div>
        </section>
      )
    }
  </article>

  <PageClosingCTA
    heading={useCase.heroTitle}
    lead={useCase.tagline}
    href={buildSignupUrl({ useCase: useCase.slug })}
    fathomTrack={fathomSignup.useCaseDetail(useCase.slug)}
  />

  <RelatedBlogPosts posts={relatedBlogPosts} />
</BaseLayout>

<style>
  .use-case-audiences {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .use-case-audiences__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    background: var(--color-card);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: border-color 150ms ease, background-color 150ms ease, color 150ms ease;
  }
  .use-case-audiences__pill:hover {
    border-color: color-mix(in srgb, var(--use-case-ink) 35%, var(--color-rule));
    background: color-mix(in oklab, var(--use-case-ink) 10%, var(--color-paper));
    color: var(--use-case-ink);
  }
  .use-case-audiences__pill :global(svg) {
    width: 0.95rem;
    height: 0.95rem;
    color: var(--use-case-ink);
  }

  .prose-letter :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
