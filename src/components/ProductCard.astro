---
/**
 * ProductCard — a card from the Figma "Home" frame's feature carousel: white
 * card, one or two content pills, a title, a body line, then a screenshot in a
 * bottom panel (bleeds, clipped). Used in the horizontal scroll row on the
 * homepage. Screenshots live at /app-*.png (see index.astro cards data).
 */
import ContentPill from "./ContentPill.astro";
import OptimizedImage from "./OptimizedImage.astro";

type PillType = "note" | "scripture" | "highlight" | "folder" | "thread";

interface Props {
  pills: PillType[];
  title: string;
  body: string;
  image: string;
  imageAlt: string;
}

const { pills, title, body, image, imageAlt } = Astro.props;
---

<article class="pcard">
  <div class="pcard__body">
    <div class="pcard__head">
      <div class="pcard__pills">
        {pills.map((p) => <ContentPill type={p} />)}
      </div>
      <h3 class="pcard__title">{title}</h3>
    </div>
    <p class="pcard__text">{body}</p>
  </div>
  <div class="pcard__shot">
    <OptimizedImage src={image} alt={imageAlt} width={1054} height={480} loading="lazy" />
  </div>
</article>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-card);
    border: 1px solid var(--color-rule);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .pcard__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
    padding: 24px;
  }
  .pcard__head { display: flex; flex-direction: column; gap: 1rem; }
  .pcard__pills { display: flex; flex-wrap: wrap; gap: 0.56rem; font-size: calc(1.25rem - 4px); }
  .pcard__pills :global(.cpill) {
    padding: 0.28em 0.55em;
  }
  .pcard__pills :global(.cpill__icon) {
    font-size: 0.625em;
  }
  .pcard__title {
    font-family: "Google Sans Flex", "Google Sans", ui-sans-serif, system-ui, sans-serif;
    font-weight: 600;
    font-variation-settings: "wdth" 100, "ROND" 0;
    font-size: 1.375rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .pcard__text {
    font-family: "Google Sans", ui-sans-serif, system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  /* Screenshot panel — height follows the image. */
  .pcard__shot {
    flex-shrink: 0;
    border-top: 1px solid var(--color-rule);
    overflow: hidden;
    background: var(--color-warm);
    line-height: 0;
  }
  .pcard__shot picture,
  .pcard__shot img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
