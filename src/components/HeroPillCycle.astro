---
/**
 * HeroPillCycle — the cycling headline pill: note → scripture → highlight →
 * folder → thread, auto-advancing on a timer. The capsule fits its own word
 * each time (no shared fixed width) — short words like "note" get a small
 * pill, longer ones like "scripture" get a wider one. Only the active pill is
 * in-flow (sizing the inline slot); the rest sit centered on top of it,
 * faded out, so the swap reads as a quick crossfade + pop rather than a
 * reflow jump.
 *
 * Honors prefers-reduced-motion (freezes on `note`).
 */
import ContentPill from "./ContentPill.astro";

const TYPES = ["note", "scripture", "highlight", "folder", "thread"] as const;
---

<span class="pillcycle" data-pillcycle>
  {TYPES.map((type, i) => (
    <span class:list={["pillcycle__item", i === 0 && "is-active"]} data-pill-item>
      <ContentPill type={type} />
    </span>
  ))}
</span>

<style>
  .pillcycle {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    vertical-align: baseline;
    white-space: nowrap;
  }
  .pillcycle :global(.cpill) {
    align-items: baseline;
    line-height: 1;
    padding-block: 0.08em 0.12em;
  }
  .pillcycle :global(.cpill__icon) {
    align-self: center;
  }
  .pillcycle__item {
    opacity: 0;
    transform: translateY(0.24em) scale(0.92);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
    will-change: opacity, transform;
  }
  .pillcycle__item:not(.is-active) {
    position: absolute;
    inset: 0;
    margin: auto;
    width: max-content;
    height: max-content;
    pointer-events: none;
  }
  .pillcycle__item.is-active {
    position: relative;
    opacity: 1;
    transform: translateY(0) scale(1);
    transition:
      opacity 220ms cubic-bezier(0.16, 1, 0.3, 1) 90ms,
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1) 90ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .pillcycle__item { transition: none; }
  }
</style>

<script>
  const INTERVAL = 2000;
  document.querySelectorAll<HTMLElement>("[data-pillcycle]").forEach((root) => {
    const items = Array.from(root.querySelectorAll<HTMLElement>("[data-pill-item]"));
    if (items.length < 2) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    let i = 0;
    setInterval(() => {
      items[i].classList.remove("is-active");
      i = (i + 1) % items.length;
      items[i].classList.add("is-active");
    }, INTERVAL);
  });
</script>
