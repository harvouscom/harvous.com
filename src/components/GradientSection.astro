---
/**
 * GradientSection — a bold, theme-stable gradient "moment" card (Lattice's
 * accent blocks). Fixed colors so it stays vivid in day and night. Centered
 * heading + body, optional CTA slot and visual slot.
 */
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  gradient?: "blue" | "violet" | "mint";
}
const { eyebrow, title, body, gradient = "blue" } = Astro.props;
---

<section class="gsec">
  <div class:list={["gsec__card", `gsec__card--${gradient}`]} data-reveal="scale">
    <div class="gsec__glow" aria-hidden="true"></div>
    <div class="gsec__inner">
      {eyebrow && <p class="gsec__eyebrow">{eyebrow}</p>}
      <h2 class="gsec__title">{title}</h2>
      {body && <p class="gsec__body">{body}</p>}
      {Astro.slots.has("cta") && <div class="gsec__cta"><slot name="cta" /></div>}
      {Astro.slots.has("visual") && <div class="gsec__visual"><slot name="visual" /></div>}
    </div>
  </div>
</section>

<style>
  .gsec { padding: 1.25rem; }
  .gsec__card {
    position: relative;
    margin-inline: auto;
    max-width: 72rem;
    overflow: hidden;
    border-radius: 2rem;
    box-shadow: 0 30px 70px -30px rgba(0, 110, 255, 0.55);
  }
  .gsec__card--blue { background: linear-gradient(171deg, #2bb5ff 7%, #006eff 93%); }
  .gsec__card--violet { background: linear-gradient(155deg, #b06ae0 0%, #9d5ac7 52%, #7e3fb0 100%); }
  .gsec__card--mint { background: linear-gradient(155deg, #44cf6a 0%, #2bc71e 52%, #1c9e14 100%); }

  .gsec__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(60% 80% at 50% -10%, rgba(255, 255, 255, 0.28), transparent 70%),
      radial-gradient(70% 90% at 50% 120%, rgba(255, 232, 168, 0.18), transparent 70%);
  }
  .gsec__inner {
    position: relative;
    padding: 4rem 1.5rem;
    text-align: center;
    color: #fff;
  }
  @media (min-width: 768px) {
    .gsec__inner { padding: 5.5rem 1.5rem; }
  }
  .gsec__eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }
  .gsec__title {
    margin-top: 0.6rem;
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .gsec__body {
    margin: 1.25rem auto 0;
    max-width: 34rem;
    font-size: 1.125rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.9);
  }
  .gsec__cta { margin-top: 2rem; display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }
  .gsec__visual { margin-top: 2.5rem; }
</style>
