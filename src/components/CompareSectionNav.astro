---
/**
 * Compare hub category nav — thin wrapper around shared HubSectionNav.
 */
import HubSectionNav from "./HubSectionNav.astro";

interface NavItem {
  id: string;
  label: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<HubSectionNav
  items={items}
  ariaLabel="Compare categories"
  selectLabel="Jump to category"
  selectId="compare-category-select"
/>
