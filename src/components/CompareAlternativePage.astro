---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageClosingCTA from "./PageClosingCTA.astro";
import CTAButton from "./CTAButton.astro";
import CompareHonestBias from "./CompareHonestBias.astro";
import type { CompareEntry } from "../lib/compare-data.ts";
import type { CompareAlternativeSeoPage, ComparePick } from "../lib/compare-seo-pages.ts";
import { fathomSignup } from "../lib/fathom-events.ts";
import "../styles/compare.css";

interface Props {
  page: CompareAlternativeSeoPage;
  target: CompareEntry;
  picks: ComparePick[];
  jsonLd: Record<string, unknown>;
  noindex?: boolean;
}

const { page, target, picks, jsonLd, noindex = false } = Astro.props;
---

<BaseLayout title={page.seoTitle} description={page.seoDescription} jsonLd={jsonLd} noindex={noindex}>
  <article class="compare-guide">
    {noindex && (
      <div class="compare-guide__draft-banner" role="status">
        Draft — not indexed. Set <code>draft: false</code> in compare-seo-pages.ts to publish.
      </div>
    )}
    <header class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-3xl px-5 py-10 md:py-14">
        <div data-reveal>
          <div class="text-center">
            <h1 class="font-display text-4xl leading-[1.05] md:text-5xl">{page.h1}</h1>
            <p class="compare-guide__lead mx-auto mt-5 text-lg leading-relaxed text-[var(--color-ink-soft)]">
              {page.lead}
            </p>
            <div class="mt-6">
              <a href={`/compare/${target.slug}/`} class="text-sm font-medium text-[var(--color-accent)] hover:underline">
                Read the full Harvous vs {target.name} comparison →
              </a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="mx-auto max-w-5xl px-5 py-14 md:py-16" data-reveal style="--reveal-delay: 80ms;">
      <ol class="compare-guide__list">
        {
          picks.map((pick, index) => (
            <li class:list={["compare-guide__card", pick.isHarvous && "compare-guide__card--harvous"]}>
              {
                pick.isHarvous && (
                  <CompareHonestBias id={`honest-bias-${page.slug}`} />
                )
              }
              <div class="compare-guide__card-head">
                <div class="compare-guide__icon-wrap">
                  <img
                    class="compare-guide__icon"
                    src={pick.competitorImage}
                    alt=""
                    width="44"
                    height="44"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                  <span class="compare-guide__rank tabular-nums">{index + 1}</span>
                </div>
                <h3 class="compare-guide__name">{pick.name}</h3>
              </div>
              <p class="compare-guide__card-intro">{pick.intro}</p>
              <dl class="compare-guide__card-meta">
                <div>
                  <dt>Best for</dt>
                  <dd>{pick.idealFor}</dd>
                </div>
                <div>
                  <dt>Tradeoff</dt>
                  <dd>{pick.drawback}</dd>
                </div>
              </dl>
              <div class="compare-guide__card-actions">
                {
                  pick.isHarvous ? (
                    <CTAButton
                      href="https://app.harvous.com/sign-up"
                      variant="primary"
                      size="md"
                      external
                      fathomTrack={fathomSignup.compareDetail(page.slug)}
                    >
                      Sign up free
                    </CTAButton>
                  ) : (
                    <>
                      <a href={pick.compareHref} class="btn-pill text-sm">
                        Harvous vs {pick.name}
                      </a>
                      {
                        pick.competitorLink && (
                          <a
                            href={pick.competitorLink}
                            target="_blank"
                            rel="noopener noreferrer nofollow"
                            class="text-sm text-[var(--color-ink-faint)] hover:text-[var(--color-ink)]"
                          >
                            Visit {pick.name}
                          </a>
                        )
                      }
                    </>
                  )
                }
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="frame-divider mx-auto max-w-3xl px-5 py-14 md:py-16" data-reveal style="--reveal-delay: 120ms;">
      <div class="prose-letter space-y-8">
        {
          page.whenToChoose.map((block) => (
            <div>
              <h2 class="text-xl font-semibold text-[var(--color-ink)]">{block.heading}</h2>
              <p class="mt-3 text-[var(--color-ink-soft)]">{block.body}</p>
            </div>
          ))
        }
      </div>
    </section>
  </article>

  <PageClosingCTA
    heading={`Harvous works alongside ${target.name}.`}
    lead={target.worksBestAlongside}
    secondaryHref={`/compare/${target.slug}/`}
    secondaryLabel={`Harvous vs ${target.name}`}
    fathomTrack={fathomSignup.compareDetail(page.slug)}
  />
</BaseLayout>
