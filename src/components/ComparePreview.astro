---
/**
 * ComparePreview — carousel of /compare/ pages (homepage featured set or custom entries).
 */
import Container from "./layout/Container.astro";
import CompareCarousel from "./CompareCarousel.astro";
import { getCompareBySlug } from "../lib/compare-data.ts";
import type { CompareEntry } from "../lib/compare-data.ts";
import { fathomCompare } from "../lib/fathom-events.ts";

const DEFAULT_SLUGS = [
  "apple-notes",
  "notion",
  "youversion",
  "logos",
  "bible-note",
  "obsidian",
  "olive-tree",
  "evernote",
] as const;

interface Props {
  entries?: CompareEntry[];
  eyebrow?: string;
  title?: string;
  lead?: string;
  showAllLink?: boolean;
  fathomTrack?: string;
  fathomAllTrack?: string;
  id?: string;
}

const {
  entries: entriesProp,
  eyebrow = "Compare",
  title = "How Harvous compares",
  lead = "Not a Bible reader. Not sermon transcription. See how Harvous stacks up against the apps you might already use for reading, notes, or devotionals.",
  showAllLink = true,
  fathomTrack = fathomCompare.homeCard,
  fathomAllTrack = fathomCompare.homeAll,
  id = "compare",
} = Astro.props;

const entries =
  entriesProp ??
  DEFAULT_SLUGS.map((slug) => getCompareBySlug(slug)).filter(
    (entry): entry is NonNullable<typeof entry> => entry !== undefined
  );
---

<section class="compare-preview frame-divider" id={id}>
  <Container size="xl">
    <div class="compare-preview__head" data-reveal>
      <div class="compare-preview__head-text">
        <span class="eyebrow-pill">{eyebrow}</span>
        <h2 class="section-title">{title}</h2>
        <p class="lead">{lead}</p>
      </div>

      <div class="compare-preview__controls">
        <button type="button" class="compare-preview__arrow" data-dir="prev" aria-label="Previous comparison" disabled>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 3L5 8l5 5"/>
          </svg>
        </button>
        <button type="button" class="compare-preview__arrow" data-dir="next" aria-label="Next comparison">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 3l5 5-5 5"/>
          </svg>
        </button>
      </div>
    </div>
  </Container>

  <CompareCarousel
    class="compare-carousel--tight"
    entries={entries}
    trackLabel="App comparisons"
    fathomTrack={fathomTrack}
    showBar={false}
  />

  {
    showAllLink && (
      <Container size="xl">
        <p class="compare-preview__more" data-reveal style="--reveal-delay: 120ms;">
          <a href="/compare/" class="compare-preview__all" data-fathom-track={fathomAllTrack}>
            See all comparisons
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
        </p>
      </Container>
    )
  }
</section>

<style>
  .compare-preview {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
    overflow-x: hidden;
  }

  .compare-preview__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 2rem;
  }
  .compare-preview__head-text {
    max-width: 34rem;
  }
  @media (min-width: 640px) {
    .compare-preview__head-text .section-title {
      white-space: nowrap;
    }
  }
  .compare-preview__head-text > * + * {
    margin-top: 0.85rem;
  }
  .compare-preview__controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
  }

  .compare-preview__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    flex: none;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    background: var(--color-card);
    color: var(--color-ink-soft);
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease, opacity 150ms ease;
  }
  .compare-preview__arrow svg {
    width: 0.8rem;
    height: 0.8rem;
  }
  .compare-preview__arrow:hover:not(:disabled) {
    color: var(--color-ink);
    background: var(--color-warm);
  }
  .compare-preview__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .compare-preview__more {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    text-align: center;
  }
  .compare-preview__all {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }
  .compare-preview__all svg {
    width: 0.85rem;
    height: 0.85rem;
    transition: transform 0.15s ease;
  }
  .compare-preview__all:hover {
    text-decoration: underline;
  }
  .compare-preview__all:hover svg {
    transform: translateX(2px);
  }

</style>

<script>
  import { bindCarouselFit } from "../lib/carousel-fit.ts";

  document.querySelectorAll<HTMLElement>(".compare-preview").forEach((section) => {
    const track = section.querySelector<HTMLElement>(".compare-carousel__track");
    if (!track) return;

    bindCarouselFit({
      track,
      slideSelector: ".compare-carousel__slide",
      prevBtn: section.querySelector<HTMLButtonElement>('.compare-preview__arrow[data-dir="prev"]'),
      nextBtn: section.querySelector<HTMLButtonElement>('.compare-preview__arrow[data-dir="next"]'),
    });
  });
</script>
