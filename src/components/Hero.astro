---
import Section from "./layout/Section.astro";
import Container from "./layout/Container.astro";
import Row from "./layout/Row.astro";
import CTAButton from "./CTAButton.astro";
import OptimizedImage from "./OptimizedImage.astro";
import { fathomSignup } from "../lib/fathom-events.ts";

// Lattice-style hero: copy on the left, one framed product screenshot on the
// right, a small proof row beneath. Product shot: /app-full.png (My Home + open note).
---

<Section space="lg" class="hero">
  <Container size="xl">
    <Row cols={2} ratio="5-7" gap="lg" align="center">
      <div class="hero__copy" data-reveal>
        <span class="eyebrow-pill">A notes app for Bible study</span>
        <h1 class="section-title display-xl hero__title">
          Create your <span class="hero__nowrap">study Bible.</span>
        </h1>
        <p class="lead hero__sub">
          Notes and highlights <mark>linked to scripture</mark>, with a built-in
          dictionary and seven translations — on web, Mac, iPad, and iPhone.
        </p>
        <div class="hero__cta">
          <CTAButton href="https://app.harvous.com/sign-up" variant="primary" size="lg" external fathomTrack={fathomSignup.hero}>
            Sign up free
          </CTAButton>
          <CTAButton href="/#features" variant="secondary" size="lg">
            See features
          </CTAButton>
        </div>
      </div>

      <div class="hero__visual" data-reveal="scale" style="--reveal-delay: 120ms;">
        <div class="hero__frame">
          <OptimizedImage
            class="hero__shot"
            src="/app-full.png"
            alt="The Harvous app with a note open beside the sidebar — scripture references shown as tap-able pills, a highlighted phrase, and today's passage."
            width={2624}
            height={1360}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </Row>

    <div class="hero__proof" data-reveal>
      <span>Free to use</span>
      <span class="hero__proof-dot" aria-hidden="true"></span>
      <span>Works offline</span>
      <span class="hero__proof-dot" aria-hidden="true"></span>
      <span>7 translations</span>
      <span class="hero__proof-dot" aria-hidden="true"></span>
      <span>web · Mac · iPad · iPhone</span>
    </div>
  </Container>
</Section>

<style>
  .hero { overflow: hidden; }
  .hero__title { margin-top: 0.9rem; }
  .hero__nowrap { white-space: nowrap; }
  .hero__sub { margin-top: 1.25rem; max-width: 34rem; }
  .hero__cta {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Soft gradient frame around the product shot (Lattice-style). */
  .hero__frame {
    border-radius: 1.5rem;
    padding: clamp(0.75rem, 2vw, 1.25rem);
    background: linear-gradient(135deg, var(--tint-sky), var(--tint-violet) 60%, var(--tint-coral));
    box-shadow: var(--shadow-float);
  }
  .hero__shot {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.85rem;
  }

  .hero__proof {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-ink-faint);
  }
  .hero__proof-dot {
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.6;
  }
</style>
