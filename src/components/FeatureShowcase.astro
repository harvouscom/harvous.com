---
/**
 * FeatureShowcase — contained accent panel (Notion-style). Copy and a modest
 * visual sit side-by-side inside a rounded card, aligned with detail-page width.
 */
import Section from "./layout/Section.astro";

interface Props {
  eyebrow?: string;
  title: string;
  color?: "amber" | "sky" | "mint" | "violet" | "coral";
  reverse?: boolean;
  id?: string;
}

const { eyebrow, title, color = "sky", reverse = false, id } = Astro.props;
const visualSide = reverse ? "start" : "end";
---

<Section space="sm" id={id} class:list={["showcase", `showcase--${color}`, `showcase--visual-${visualSide}`]}>
  <div class="showcase__wrap">
    <div class="showcase__panel" data-reveal>
      <div class="showcase__layout">
        <div class="showcase__copy">
          {eyebrow && <p class="eyebrow showcase__eyebrow">{eyebrow}</p>}
          <h2 class="showcase__title font-display text-2xl md:text-3xl">{title}</h2>
          <div class="showcase__body"><slot name="body" /></div>
          {Astro.slots.has("cta") && <div class="showcase__cta"><slot name="cta" /></div>}
        </div>

        <div class="showcase__visual" data-reveal="scale" style="--reveal-delay: 100ms;">
          <div class="showcase__frame" aria-hidden="true">
            {Astro.slots.has("visual") ? (
              <slot name="visual" />
            ) : (
              <div class="showcase__placeholder" />
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Section>

<style>
  .showcase__wrap {
    margin-inline: auto;
    max-width: 56rem;
    padding-inline: var(--frame-content-pad);
  }

  .showcase__panel {
    border-radius: 1.25rem;
    overflow: hidden;
  }

  :global(section.showcase.showcase--amber) .showcase__panel { background: var(--study-dock-accent-warmAmber); }
  :global(section.showcase.showcase--sky) .showcase__panel { background: var(--study-dock-accent-skyBlue); }
  :global(section.showcase.showcase--mint) .showcase__panel { background: var(--study-dock-accent-mintGreen); }
  :global(section.showcase.showcase--violet) .showcase__panel { background: var(--study-dock-accent-violet); }
  :global(section.showcase.showcase--coral) .showcase__panel { background: var(--study-dock-accent-coralRose); }

  .showcase__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    padding: 1.75rem;
  }

  /* Text contrast is scoped to the panel. */
  :global(section.showcase.showcase--sky) .showcase__copy,
  :global(section.showcase.showcase--violet) .showcase__copy,
  :global(section.showcase.showcase--coral) .showcase__copy {
    --color-ink: #ffffff;
    --color-ink-soft: rgba(255, 255, 255, 0.88);
    --color-ink-faint: rgba(255, 255, 255, 0.74);
  }
  :global(section.showcase.showcase--amber) .showcase__copy,
  :global(section.showcase.showcase--mint) .showcase__copy {
    --color-ink: #1a1916;
    --color-ink-soft: rgba(26, 25, 22, 0.74);
    --color-ink-faint: rgba(26, 25, 22, 0.58);
  }

  .showcase__eyebrow {
    font-size: 0.6875rem;
  }

  .showcase__title {
    margin-top: 0.5rem;
    line-height: 1.12;
    color: var(--color-ink);
  }

  .showcase__body {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }
  .showcase__body :global(p + p) { margin-top: 0.75rem; }
  .showcase__cta { margin-top: 1.5rem; }

  .showcase__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .showcase__visual {
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .showcase__frame {
    width: 100%;
    border-radius: 0.875rem;
    overflow: hidden;
    line-height: 0;
    background: color-mix(in oklab, var(--color-card) 72%, transparent);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.06),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
  }

  .showcase__placeholder {
    width: 100%;
    aspect-ratio: 16 / 10;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.2) 100%);
  }

  @media (max-width: 767px) {
    .showcase__visual {
      order: -1;
    }

    .showcase__copy {
      order: 2;
    }
  }

  @media (min-width: 768px) {
    .showcase__layout {
      grid-template-columns: 1fr 1fr;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      padding: clamp(2rem, 3.5vw, 2.75rem);
    }

    :global(section.showcase.showcase--visual-start) .showcase__copy {
      order: 2;
    }

    :global(section.showcase.showcase--visual-start) .showcase__visual {
      order: 1;
    }

    .showcase__placeholder {
      aspect-ratio: 4 / 3;
      max-height: 16rem;
    }
  }

  .showcase__frame :global(img),
  .showcase__frame :global(picture),
  .showcase__frame :global(picture img) {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top center;
  }
</style>
