---
/**
 * IntroChip — inline stat pill for marketing prose (matches app home greeting chips).
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<span class:list={["intro-chip", className]}>
  <slot />
</span>

<style>
  .intro-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    vertical-align: middle;
    transform: translateY(-0.06em);
    border-radius: 999px;
    padding: 0.22em 0.62em;
    margin-inline: 0.06em;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.88em;
    line-height: 1.5;
    white-space: nowrap;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    background: var(--color-card);
    border: 0.5px solid color-mix(in oklab, var(--color-ink) 10%, var(--color-rule));
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.05),
      0 4px 12px -8px rgba(15, 23, 42, 0.1);
  }

  :global(:root[data-color-scheme="dark"]) .intro-chip {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.35),
      0 4px 12px -8px rgba(0, 0, 0, 0.45);
  }
</style>
