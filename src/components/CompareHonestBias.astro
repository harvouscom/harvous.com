---
interface Props {
  id: string;
  note: string;
}

const { id, note } = Astro.props;
---

<details class="compare-guide__bias">
  <summary class="compare-guide__bias-chip">
    Side note
    <svg class="compare-guide__bias-chevron" viewBox="0 0 12 12" aria-hidden="true">
      <path
        d="M3 4.5 6 7.5 9 4.5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </summary>
  <div class="compare-guide__bias-panel" id={id} role="note">
    <p>{note}</p>
  </div>
</details>

<script>
  // Close other bias details when one opens; close on outside click.
  document.addEventListener(
    "click",
    (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const open = document.querySelectorAll("details.compare-guide__bias[open]");
      for (const details of open) {
        if (!details.contains(target)) details.removeAttribute("open");
      }
    },
    true
  );
</script>
