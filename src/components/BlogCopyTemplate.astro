---
/**
 * Fill-in template for Bright Enough essays — layered paper stack (shared-note /
 * founder-letter look) with note-body content, not a monospace code fence.
 */
interface Props {
  body: string;
  /** Title shown on the sheet like an open note. */
  title?: string;
  eyebrow?: string;
  hint?: string;
}

const {
  body,
  title = "Lesson prep",
  eyebrow = "Template",
  hint = "Copy to clipboard",
} = Astro.props;

/** Plain text for clipboard — title + original template body. */
const copyText = `${title}\n\n${body.replace(/^\n+|\n+$/g, "")}\n`;

type Row =
  | { kind: "section"; label: string }
  | { kind: "field"; label: string; blank: string }
  | { kind: "prompt"; marker: string };

/** "PASSAGE" → "Passage"; "AIM (one sentence)" → "Aim (one sentence)"; bullets kept. */
function formatLabel(raw: string): string {
  const m = /^(\s*(?:[-•]\s*)?)(.*)$/.exec(raw);
  if (!m) return raw;
  const [, prefix, rest] = m;
  const paren = rest.indexOf("(");
  const head = (paren === -1 ? rest : rest.slice(0, paren)).trimEnd();
  const tail = paren === -1 ? "" : rest.slice(paren).trim();
  if (head.length > 0 && head === head.toUpperCase() && /[A-Z]/.test(head)) {
    const titled = head.charAt(0) + head.slice(1).toLowerCase();
    return `${prefix}${titled}${tail ? ` ${tail}` : ""}`;
  }
  return raw;
}

const BARE_PROMPT = /^\s*(?:\d+\.|[-•])\s*$/;
const LIST_PREFIX = /^\s*(?:\d+\.|[-•])\s*/;

function parseRows(raw: string): Row[] {
  const lines = raw.replace(/^\n+|\n+$/g, "").split("\n");
  const rows: Row[] = [];

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i]!;
    if (!line.trim()) continue;

    // Bare numbered / bullet prompt: "  1." → fill-in line
    const prompt = /^(\s*)(\d+\.|[-•])\s*$/.exec(line);
    if (prompt) {
      rows.push({ kind: "prompt", marker: `${prompt[1]}${prompt[2]}` });
      continue;
    }

    const field = /^(\s*)([^:]+:)(.*)$/.exec(line);
    if (!field) continue;

    const [, indent, labelWithColon, rest] = field;
    const label = `${indent}${formatLabel(labelWithColon.replace(/:$/, ""))}`;
    const blank = rest.trim();
    const isListField = LIST_PREFIX.test(line);

    // Section header (no rule) only for parent labels — Questions, Trail —
    // when kids follow. List fields themselves ("- What landed:") always get a line.
    let next = "";
    for (let j = i + 1; j < lines.length; j++) {
      if (lines[j]!.trim()) {
        next = lines[j]!;
        break;
      }
    }
    const nextIsChild =
      BARE_PROMPT.test(next) || (LIST_PREFIX.test(next) && next.includes(":"));
    if (!blank && !isListField && nextIsChild) {
      rows.push({ kind: "section", label });
      continue;
    }

    rows.push({ kind: "field", label, blank });
  }

  return rows;
}

const rows = parseRows(body);
---

<figure class="blog-copy-template">
  <div class="paper-stack blog-copy-template__stack">
    <div
      aria-hidden="true"
      class="paper-leaf absolute inset-0 rounded-[2px] border border-[var(--color-rule)] shadow-[0_8px_24px_-12px_rgba(20,18,12,0.10)]"
      style="--rot: 2.2deg; background-color: var(--paper-sheet);"
    ></div>
    <div
      aria-hidden="true"
      class="paper-leaf absolute inset-0 rounded-[2px] border border-[var(--color-rule)] shadow-[0_8px_24px_-12px_rgba(20,18,12,0.10)]"
      style="--rot: -2.8deg; background-color: var(--paper-sheet);"
    ></div>
    <div
      class="paper-leaf blog-copy-template__sheet relative rounded-[2px] border border-[var(--color-rule)] shadow-[var(--pds-paper-shadow)]"
      style="--rot: -0.6deg;
             background-color: var(--paper-sheet);
             background-image:
               radial-gradient(var(--pds-paper-grain-a) 1px, transparent 1px),
               radial-gradient(var(--pds-paper-grain-b) 1px, transparent 1px);
             background-size: 28px 28px, 17px 17px;
             background-position: 0 0, 9px 9px;"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute right-0 top-0 h-10 w-10"
        style="background: linear-gradient(225deg, var(--pds-paper-fold-a) 0%, var(--pds-paper-fold-b) 40%, transparent 60%);"
      ></div>

      <div class="blog-copy-template__kicker">
        <span>{eyebrow}</span>
        <button
          type="button"
          class="blog-copy-template__copy"
          data-blog-template-copy
          data-copy-label={hint}
          data-copied-label="Copied"
          aria-label={`${hint}: copy template to clipboard`}
        >
          <svg class="blog-copy-template__copy-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
            <path
              d="M10.5 5.5V4A1.5 1.5 0 0 0 9 2.5H4A1.5 1.5 0 0 0 2.5 4v5A1.5 1.5 0 0 0 4 10.5h1.5"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
            ></path>
          </svg>
          <span data-blog-template-copy-label>{hint}</span>
        </button>
        <textarea class="blog-copy-template__payload" data-blog-template-payload hidden readonly>{copyText}</textarea>
      </div>

      <div class="blog-copy-template__title">{title}</div>

      <div class="blog-copy-template__body">
        {
          rows.map((row) => {
            if (row.kind === "section") {
              return (
                <div class="blog-copy-template__section">{row.label}</div>
              );
            }
            if (row.kind === "prompt") {
              return (
                <div class="blog-copy-template__field blog-copy-template__field--prompt">
                  <span class="blog-copy-template__marker">{row.marker}</span>
                  <span class="blog-copy-template__rule">{"\u00a0"}</span>
                </div>
              );
            }
            return (
              <div class="blog-copy-template__field">
                <span class="blog-copy-template__label">{row.label}</span>
                <span class="blog-copy-template__rule">
                  {row.blank || "\u00a0"}
                </span>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</figure>

<style>
  .blog-copy-template {
    margin: 2rem 0;
    padding: 0.65rem 0.85rem 1.1rem;
  }

  .blog-copy-template__stack {
    position: relative;
    max-width: 26rem;
    margin-inline: 0;
  }

  .blog-copy-template__sheet {
    display: flex;
    flex-direction: column;
    padding: 1.15rem 1.35rem 1.5rem;
  }

  .blog-copy-template__kicker {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0 0 0.85rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }

  .blog-copy-template__copy {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    padding: 0.2rem 0.55rem 0.2rem 0.4rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    letter-spacing: 0.02em;
    text-transform: none;
    font: inherit;
    font-weight: 400;
    font-size: 0.75rem;
    color: var(--color-ink-faint);
    cursor: pointer;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      border-color 140ms ease;
  }
  .blog-copy-template__copy:hover {
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-card) 70%, transparent);
    border-color: var(--color-rule);
  }
  .blog-copy-template__copy:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .blog-copy-template__copy.is-copied {
    color: var(--color-accent);
    font-weight: 500;
  }
  .blog-copy-template__copy-icon {
    width: 0.85rem;
    height: 0.85rem;
    flex: none;
  }
  .blog-copy-template__payload {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Div (not h3) so .prose-post h3 margins don’t inflate the sheet */
  .blog-copy-template__title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.15;
    color: var(--color-ink);
  }

  .blog-copy-template__body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink);
  }

  .blog-copy-template__section {
    margin: 0.15rem 0 0;
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Pull numbered prompts tighter under their section label */
  .blog-copy-template__section + .blog-copy-template__field--prompt {
    margin-top: -0.2rem;
  }

  .blog-copy-template__field {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  .blog-copy-template__field--prompt {
    gap: 0.35rem;
    padding-left: 0.1rem;
  }

  .blog-copy-template__label,
  .blog-copy-template__marker {
    flex: none;
    font-weight: 600;
    color: var(--color-ink);
  }

  .blog-copy-template__marker {
    font-weight: 500;
    color: var(--color-ink-soft);
    font-variant-numeric: tabular-nums;
    min-width: 1.25em;
  }

  .blog-copy-template__rule {
    flex: 1 1 auto;
    min-width: 3rem;
    border-bottom: 1px solid color-mix(in oklab, var(--color-ink) 14%, transparent);
    color: var(--color-ink-soft);
    line-height: 1.4;
  }
</style>

<script>
  function initBlogTemplateCopy(root: HTMLElement) {
    const btn = root.querySelector<HTMLButtonElement>("[data-blog-template-copy]");
    const label = root.querySelector<HTMLElement>("[data-blog-template-copy-label]");
    const payload = root.querySelector<HTMLTextAreaElement>("[data-blog-template-payload]");
    if (!btn || !label || !payload) return;

    const idle = btn.dataset.copyLabel || "Copy to clipboard";
    const done = btn.dataset.copiedLabel || "Copied";
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    const setCopied = (copied: boolean) => {
      btn.classList.toggle("is-copied", copied);
      label.textContent = copied ? done : idle;
      btn.setAttribute("aria-label", copied ? "Template copied" : `${idle}: copy template to clipboard`);
    };

    btn.addEventListener("click", async () => {
      const text = payload.value;
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          payload.hidden = false;
          payload.focus();
          payload.select();
          document.execCommand("copy");
          payload.hidden = true;
        }
        setCopied(true);
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(() => setCopied(false), 1800);
      } catch {
        setCopied(false);
      }
    });
  }

  document.querySelectorAll<HTMLElement>(".blog-copy-template").forEach(initBlogTemplateCopy);
</script>
