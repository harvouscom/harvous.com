---
import CTAButton from "./CTAButton.astro";

interface Props {
  heading: string;
  lead?: string;
  href?: string;
  label?: string;
  fathomTrack?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  secondaryFathomTrack?: string;
}

const {
  heading,
  lead,
  href = "https://app.harvous.com/sign-up",
  label = "Sign up free",
  fathomTrack,
  secondaryHref,
  secondaryLabel,
  secondaryFathomTrack,
} = Astro.props;
---

<section class="page-closing-cta frame-divider">
  <div class="page-closing-cta__inner" data-reveal>
    <h2 class="section-title display-lg page-closing-cta__heading">{heading}</h2>
    {lead && <p class="page-closing-cta__lead">{lead}</p>}
    <div class="page-closing-cta__action">
      <CTAButton href={href} variant="primary" size="lg" external fathomTrack={fathomTrack}>
        {label}
      </CTAButton>
      {
        secondaryHref && secondaryLabel && (
          <CTAButton href={secondaryHref} variant="secondary" size="lg" fathomTrack={secondaryFathomTrack}>
            {secondaryLabel}
          </CTAButton>
        )
      }
    </div>
  </div>
</section>

<style>
  .page-closing-cta__inner {
    margin-inline: auto;
    max-width: 48rem;
    padding: 5rem 1.25rem;
    text-align: center;
  }
  .page-closing-cta__heading {
    text-wrap: pretty;
  }
  .page-closing-cta__lead {
    max-width: 34rem;
    margin-inline: auto;
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  .page-closing-cta__action {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
