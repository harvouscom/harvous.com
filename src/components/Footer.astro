---
import Container from "./layout/Container.astro";
import OptimizedImage from "./OptimizedImage.astro";

const year = new Date().getFullYear();

const groups = [
  {
    label: "Product",
    links: [
      { label: "Use cases", href: "/use-cases/" },
      { label: "Who it's for", href: "/for/" },
      { label: "Compare", href: "/compare/" },
      { label: "Pricing", href: "/pricing/" },
      { label: "Add-ons", href: "/pricing/" },
    ],
  },
  {
    label: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "Release Notes", href: "/release-notes/" },
      { label: "Support", href: "/support/" },
      { label: "Status", href: "https://status.harvous.com/", external: true },
    ],
  },
  {
    label: "Legal",
    links: [
      { label: "Privacy", href: "/privacy/" },
      { label: "Terms", href: "/terms/" },
    ],
  },
];
---

<footer class="site-footer border-t border-[var(--color-rule)] pt-10 pb-8 md:pt-14">
  <Container size="xl">
    <div class="grid gap-10 md:grid-cols-[minmax(12rem,1fr)_minmax(0,2.2fr)] md:gap-12 md:items-start">
      <div class="max-w-64">
        <a href="/" class="inline-flex items-center gap-2.5 text-[var(--color-ink)] no-underline" aria-label="Harvous — Home">
          <OptimizedImage
            src="/images/harvous-icon-sm.png"
            alt=""
            width={64}
            height={64}
            class="size-6 rounded-[0.35rem]"
          />
          <span class="font-display text-lg font-semibold leading-none tracking-[-0.02em]">Harvous</span>
        </a>
        <p class="mt-3 text-sm leading-normal text-[var(--color-ink-faint)] text-pretty">
          A notes app for remembering Bible study.
        </p>
        <p class="mt-4 text-xs leading-normal text-[var(--color-ink-faint)] text-pretty">
          © {year}{" "}
          <a href="https://testamentmade.com" class="text-inherit no-underline transition-colors duration-150 hover:text-[var(--color-ink)]">
            Testament Made LLC
          </a>
          <span class="mx-1.5" aria-hidden="true">·</span>
          <a
            href="https://github.com/harvouscom/harvous.com/blob/main/LICENSE"
            rel="license"
            class="text-inherit no-underline transition-colors duration-150 hover:text-[var(--color-ink)]"
          >
            CC BY 4.0
          </a>
        </p>
      </div>

      <nav class="grid grid-cols-2 gap-x-6 gap-y-7 sm:grid-cols-3 sm:gap-8" aria-label="Footer">
        {
          groups.map((group) => (
            <div>
              <h2 class="m-0 mb-3 text-[0.6875rem] font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-faint)]">
                {group.label}
              </h2>
              <ul class="m-0 flex list-none flex-col gap-3 p-0" role="list">
                {group.links.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      class="text-sm whitespace-nowrap text-[var(--color-ink-soft)] no-underline transition-colors duration-150 hover:text-[var(--color-ink)]"
                      {...(l.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    >
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>
  </Container>
</footer>

<style>
  @media (max-width: 639px) {
    .site-footer {
      padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px) + 0.75rem);
    }
  }
</style>
