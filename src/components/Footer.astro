---
import Container from "./layout/Container.astro";

const year = new Date().getFullYear();

const links = [
  { label: "Compare", href: "/compare/" },
  { label: "Release Notes", href: "/release-notes/" },
  { label: "Support", href: "/support/" },
  { label: "Status", href: "https://status.harvous.com/" },
  { label: "Privacy", href: "/privacy" },
  { label: "Terms", href: "/terms" },
];
---

<footer class="site-footer">
  <Container size="xl">
    <div>
      <div class="site-footer__bar">
        <nav class="site-footer__nav" aria-label="Footer">
          {links.map((l) => (
            <a href={l.href} class="site-footer__link">{l.label}</a>
          ))}
        </nav>
        <p>
          © {year} Testament Made LLC.{" "}
          <a
            href="https://github.com/harvouscom/harvous.com/blob/main/LICENSE"
            class="transition hover:text-[var(--color-ink)]"
            rel="license"
          >
            CC BY 4.0
          </a>
        </p>
      </div>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .site-footer__bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--color-ink-faint);
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(3, auto);
    justify-content: center;
    justify-items: center;
    column-gap: 1.25rem;
    row-gap: 0.5rem;
    max-width: 100%;
  }

  .site-footer__link {
    white-space: nowrap;
    transition: color 150ms ease;
  }
  .site-footer__link:hover {
    color: var(--color-ink);
  }

  @media (min-width: 640px) {
    .site-footer__bar {
      flex-direction: row-reverse;
    }

    .site-footer__nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-items: center;
      gap: 0.5rem 1.25rem;
    }
  }

  @media (max-width: 639px) {
    .site-footer {
      padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px) + 0.75rem);
    }
  }
</style>
