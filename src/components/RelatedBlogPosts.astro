---
/**
 * Compact “From Bright Enough” strip for product pages — intro + two posts.
 */
import type { CollectionEntry } from "astro:content";
import BlogCard from "./BlogCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  lead?: string;
}

const {
  posts,
  lead = "Bright Enough — teaching craft, retention, and habits that show up after Sunday.",
} = Astro.props;

const shown = posts.slice(0, 2);
---

{
  shown.length > 0 && (
    <section class="related-blog frame-divider" aria-labelledby="related-blog-title">
      <div class="related-blog__inner detail-content py-10 md:py-12">
        <div class="related-blog__intro">
          <h2
            id="related-blog-title"
            class="font-display text-xl leading-snug tracking-tight md:text-2xl"
          >
            From the blog
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)]">{lead}</p>
          <a
            href="/blog/"
            class="related-blog__more mt-4 inline-flex text-sm font-medium text-[var(--color-accent)] hover:underline"
          >
            More in Bright Enough →
          </a>
        </div>
        <ul class="related-blog__grid" data-reveal="stagger" role="list">
          {shown.map((p) => (
            <li>
              <BlogCard
                title={p.data.title}
                description={p.data.description}
                publishDate={p.data.publishDate}
                category={p.data.category}
                slug={p.id}
                readingTime={p.data.readingTime}
                draft={p.data.draft}
                variant="spotlight"
              />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}

<style>
  .related-blog__inner {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .related-blog__inner {
      grid-template-columns: minmax(12rem, 0.85fr) minmax(0, 1.4fr);
      gap: 2rem 2.5rem;
      align-items: start;
    }
  }

  .related-blog__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .related-blog__grid :global(.blog-spotlight) {
    height: 100%;
    box-shadow: none;
    border: 1px solid var(--color-rule);
    background: color-mix(in oklab, var(--color-paper) 88%, white);
  }

  .related-blog__grid :global(.blog-spotlight:hover) {
    box-shadow: none;
    transform: none;
    border-color: color-mix(in oklab, var(--color-ink) 18%, var(--color-rule));
    background: white;
  }
</style>
