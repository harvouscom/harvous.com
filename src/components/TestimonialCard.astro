---
/**
 * TestimonialCard — a single open quote: display-type blockquote text with
 * yellow mark highlights, then a quiet inline attribution row (small initials
 * circle + name · date). No card surface, border, or shadow.
 */
interface Props {
  name: string;
  when: string;
}

const { name, when } = Astro.props;
const initial = name.trim().charAt(0).toUpperCase();
---

<figure class="testimonial">
  <blockquote class="testimonial__quote">
    <slot />
  </blockquote>
  <figcaption class="testimonial__attr">
    <span class="testimonial__avatar" aria-hidden="true">{initial}</span>
    <span class="testimonial__name">{name}</span>
    <span class="testimonial__sep" aria-hidden="true">·</span>
    <time class="testimonial__when" datetime={when}>{when}</time>
  </figcaption>
</figure>

<style>
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    min-width: 0;
  }

  .testimonial__quote {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 1.9vw, 1.3125rem);
    line-height: 1.45;
    letter-spacing: -0.015em;
    font-weight: 600;
    color: var(--color-ink);
  }

  .testimonial__quote :global(mark) {
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .testimonial__attr {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem 0.35rem;
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  .testimonial__avatar {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 999px;
    background: var(--color-warm);
    color: var(--color-ink-soft);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .testimonial__name {
    font-weight: 600;
    color: var(--color-ink-soft);
  }

  .testimonial__sep {
    color: var(--color-ink-faint);
  }

  .testimonial__when {
    color: var(--color-ink-faint);
  }
</style>
