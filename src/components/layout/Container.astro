---
/**
 * Container — centered max-width wrapper with consistent horizontal gutters.
 * Pair inside <Section>. Sizes map to the measures already used across the site.
 */
interface Props {
  size?: "prose" | "sm" | "md" | "lg" | "xl" | "full";
  class?: string;
}

const { size = "xl", class: className = "" } = Astro.props;
---

<div class:list={["container", `container--${size}`, className]}>
  <slot />
</div>

<style>
  .container {
    margin-inline: auto;
    width: 100%;
    /* Symmetric inset: --frame-content-pad = 2× --frame-inset so the gap
       hairline → content matches viewport → hairline (see global.css). */
    padding-inline: var(--frame-content-pad);
  }

  .container--prose { max-width: 36rem; }
  .container--sm { max-width: 42rem; }
  .container--md { max-width: 56rem; }
  .container--lg { max-width: 64rem; }
  .container--xl { max-width: 72rem; }
  .container--full { max-width: none; }
</style>
