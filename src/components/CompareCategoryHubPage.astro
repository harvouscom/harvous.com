---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageClosingCTA from "./PageClosingCTA.astro";
import CTAButton from "./CTAButton.astro";
import { Icon } from "astro-icon/components";
import CompareHonestBias from "./CompareHonestBias.astro";
import type { CompareCategorySeoPage, ComparePick } from "../lib/compare-seo-pages.ts";
import { getHonestNoteForPage } from "../lib/compare-seo-pages.ts";
import { fathomSignup } from "../lib/fathom-events.ts";
import "../styles/compare.css";

interface Props {
  page: CompareCategorySeoPage;
  picks: ComparePick[];
  jsonLd: Record<string, unknown>;
  noindex?: boolean;
}

const { page, picks, jsonLd, noindex = false } = Astro.props;
const honestNote = getHonestNoteForPage(page, picks);

const decisionRows = [
  { label: "Built-in Bible reader", harvous: "No — type a reference, open inline text", others: "Varies — readers yes, notes apps no" },
  { label: "Sermon transcription", harvous: "No", others: "Some Bible Notes apps yes; general notes no" },
  { label: "Scripture-linked notes", harvous: "Yes — pills, highlights, threads", others: "Dedicated apps yes; general notes DIY" },
  { label: "Price", harvous: "Free for personal study", others: "Varies — many free tiers, Logos paid" },
];
---

<BaseLayout title={page.seoTitle} description={page.seoDescription} jsonLd={jsonLd} noindex={noindex}>
  <article class="compare-guide">
    {noindex && (
      <div class="compare-guide__draft-banner" role="status">
        Draft — not indexed. Set <code>draft: false</code> in compare-seo-pages.ts to publish.
      </div>
    )}
    <header class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-3xl px-5 py-10 md:py-14">
        <div data-reveal>
          <div class="text-center">
            <h1 class="font-display text-4xl leading-[1.05] md:text-5xl">{page.h1}</h1>
            <p class="compare-guide__lead mx-auto mt-5 text-lg leading-relaxed text-[var(--color-ink-soft)]">
              {page.lead}
            </p>
          </div>
        </div>
      </div>
    </header>

    <section class="mx-auto max-w-5xl px-5 py-14 md:py-16" data-reveal style="--reveal-delay: 80ms;">
      <ol class="compare-guide__list">
        {
          picks.map((pick, index) => (
            <li class:list={["compare-guide__card", pick.isHarvous && "compare-guide__card--harvous"]}>
              {
                pick.isHarvous && (
                  <CompareHonestBias id={`honest-bias-${page.slug}`} note={honestNote} />
                )
              }
              <div class="compare-guide__card-head">
                <div class="compare-guide__icon-wrap">
                  <img
                    class="compare-guide__icon"
                    src={pick.competitorImage}
                    alt=""
                    width="44"
                    height="44"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                  <span class="compare-guide__rank tabular-nums">{index + 1}</span>
                </div>
                <h3 class="compare-guide__name">{pick.name}</h3>
              </div>
              <p class="compare-guide__card-intro">{pick.intro}</p>
              <p class="mt-3 text-sm text-[var(--color-ink-soft)]">
                <span class="font-medium text-[var(--color-ink)]">Best for:</span> {pick.idealFor}
              </p>
              <div class="compare-guide__card-actions">
                {
                  pick.isHarvous ? (
                    <CTAButton
                      href="https://app.harvous.com/sign-up"
                      variant="primary"
                      size="md"
                      external
                      fathomTrack={fathomSignup.compareDetail(page.slug)}
                    >
                      Sign up free
                    </CTAButton>
                  ) : (
                    <a href={pick.compareHref} class="btn-pill text-sm">
                      Harvous vs {pick.name}
                    </a>
                  )
                }
              </div>
            </li>
          ))
        }
        <li class="compare-guide__card compare-guide__card--more">
          <div class="compare-guide__card-head">
            <div class="compare-guide__icon-wrap">
              <span class="compare-guide__icon compare-guide__icon--more" aria-hidden="true">
                <Icon name="fa6-solid:table-cells" />
              </span>
            </div>
            <h3 class="compare-guide__name">Compare all apps</h3>
          </div>
          <p class="compare-guide__card-intro">
            This shortlist is a start. See how Harvous compares to Bible readers, notes apps, study suites, and more.
          </p>
          <div class="compare-guide__card-actions">
            <a href="/compare/" class="btn-pill text-sm">
              Browse all comparisons
            </a>
          </div>
        </li>
      </ol>
    </section>

    <section class="frame-divider mx-auto max-w-5xl px-5 py-14 md:py-16" data-reveal style="--reveal-delay: 120ms;">
      <h2 class="font-display text-2xl leading-snug md:text-3xl">How to choose</h2>

      <div class="compare-guide__choose">
        <div class="compare-guide__choose-glance">
          <h3 class="compare-guide__choose-label">At a glance</h3>
          <div class="compare-detail__table-wrap">
            <table class="compare-detail__table">
              <thead>
                <tr>
                  <th scope="col"></th>
                  <th scope="col">Harvous</th>
                  <th scope="col">Typical alternatives</th>
                </tr>
              </thead>
              <tbody>
                {
                  decisionRows.map((row) => (
                    <tr>
                      <th scope="row">{row.label}</th>
                      <td>{row.harvous}</td>
                      <td>{row.others}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <div class="compare-guide__choose-paths">
          <h3 class="compare-guide__choose-label">Pick a path</h3>
          <ul class="compare-guide__choose-grid" role="list">
            {
              page.whenToChoose.map((block, i) => (
                <li class:list={["compare-guide__choose-card", i === 0 && "compare-guide__choose-card--harvous"]}>
                  <h4 class="compare-guide__choose-card-title">{block.heading}</h4>
                  <p class="compare-guide__choose-card-body">{block.body}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>
  </article>

  <PageClosingCTA
    heading="Try a notes-first Bible study app."
    lead="Harvous is free for personal study — unlimited notes, scripture pills, highlights, and threads."
    fathomTrack={fathomSignup.compareDetail(page.slug)}
  />
</BaseLayout>
