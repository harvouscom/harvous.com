---
import { fathomSignin, fathomSignup } from "../lib/fathom-events.ts";
import OptimizedImage from "./OptimizedImage.astro";

const APP_SIGN_IN = "https://app.harvous.com/sign-in";

const navLinks = [
  { href: "/#features", label: "Features" },
  { href: "/use-cases/", label: "Use cases" },
  { href: "/compare/", label: "Compare" },
  { href: "/pricing/", label: "Pricing" },
];

// Scroll threshold (px) at which the header switches from the flat,
// full-width top-of-page bar into the floating pill. Kept in sync with the
// inline script below.
const SCROLL_THRESHOLD = 16;
---

<header
  class="site-header sticky"
  id="site-header"
  data-scroll-threshold={SCROLL_THRESHOLD}
>
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="Harvous — Home">
      <OptimizedImage
        src="/images/harvous-icon-sm.png"
        alt=""
        width={32}
        height={32}
        loading="eager"
      />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {navLinks.map((link) => (
        <a href={link.href} class="site-header__link">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a href={APP_SIGN_IN} class="site-header__link" data-fathom-track={fathomSignin.header}>
        Sign in
      </a>
      <a href="https://app.harvous.com/sign-up" class="btn-pill site-header__cta" data-fathom-track={fathomSignup.header}>
        Sign up free
      </a>

      <button
        type="button"
        class="site-header__menu-toggle"
        id="site-header-menu-toggle"
        aria-expanded="false"
        aria-controls="site-header-mobile-nav"
      >
        <span class="site-header__menu-toggle-label">Menu</span>
        <svg class="site-header__menu-icon site-header__menu-icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 5.5h14M3 10h14M3 14.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <svg class="site-header__menu-icon site-header__menu-icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div class="site-header__mobile-nav" id="site-header-mobile-nav" aria-hidden="true">
    <button type="button" class="site-header__mobile-nav-backdrop" id="site-header-mobile-backdrop" tabindex="-1" aria-label="Close menu"></button>
    <nav class="site-header__mobile-nav-panel" aria-label="Mobile">
      <div class="site-header__mobile-nav-links">
        {navLinks.map((link) => (
          <a href={link.href} class="site-header__mobile-link">
            {link.label}
          </a>
        ))}
        <a href={APP_SIGN_IN} class="site-header__mobile-link" data-fathom-track={fathomSignin.header}>
          Sign in
        </a>
      </div>
      <a href="https://app.harvous.com/sign-up" class="btn-accent site-header__mobile-cta" data-fathom-track={fathomSignup.header}>
        Sign up free
      </a>
    </nav>
  </div>
</header>

<style>
  /* Single easing convention used across this codebase's scroll/state
     animations (paper-stack fan-in + reveal-on-scroll in global.css,
     FaqItem's open transition) — reused here so the header morph reads as
     part of the same motion language rather than its own thing. */
  .site-header {
    --header-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --header-duration: 360ms;
    --pill-inset: 0.75rem;

    top: 0;
    z-index: 40;
    width: 100%;
    isolation: isolate;
    transition: top var(--header-duration) var(--header-ease);
  }
  /* Full-band paper fill in flat state — solid top chrome above the frame. */
  .site-header:not(.is-scrolled) {
    background-color: var(--color-paper);
  }
  .site-header.is-scrolled {
    top: 0.75rem;
  }
  .site-header.is-menu-open {
    z-index: 100;
  }

  .site-header__inner {
    position: relative;
    display: grid;
    grid-template-columns: auto auto;
    align-items: center;
    justify-content: space-between;
    column-gap: 0.75rem;
    width: 100%;
    box-sizing: border-box;
    /* Resting (flat) state spans the full bar; once scrolled this shrinks to
       --pill-width (measured in the inline script below from the row's own
       natural content width) so the browser can smoothly interpolate the
       width instead of snapping to the `fit-content` keyword. */
    max-width: 100%;
    margin-inline: auto;
    padding: 0.75rem 1.25rem;
    border: 1px solid transparent;
    border-radius: 0px;
    /* Opaque in flat state so the header bar reads as a solid top chrome. */
    background-color: var(--color-paper);
    /* Same shadow "recipe" (offsets/blur) in both states, only the alpha
       changes — lets box-shadow cross-fade smoothly instead of popping in
       from `none`. */
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0),
      0 8px 24px -12px rgba(15, 23, 42, 0);
    backdrop-filter: blur(0px);
    transition:
      max-width var(--header-duration) var(--header-ease),
      border-radius var(--header-duration) var(--header-ease),
      border-color var(--header-duration) var(--header-ease),
      background-color var(--header-duration) var(--header-ease),
      box-shadow var(--header-duration) var(--header-ease),
      backdrop-filter var(--header-duration) var(--header-ease);
  }
  /* Bottom hairline — only present in the flat, top-of-page state; the
     floating pill already has its own border, so this fades out together
     with the rest of the chrome change. */
  .site-header__inner::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: var(--color-rule);
    opacity: 1;
    transition: opacity var(--header-duration) var(--header-ease);
    pointer-events: none;
  }

  .site-header.is-scrolled .site-header__inner {
    max-width: var(--pill-width, fit-content);
    min-width: var(--pill-width, fit-content);
    padding: var(--pill-inset);
    gap: var(--pill-inset);
    column-gap: var(--pill-inset);
    border-radius: 999px;
    border-color: var(--color-rule);
    background-color: color-mix(in oklab, var(--color-card) 88%, transparent);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 8px 24px -12px rgba(15, 23, 42, 0.1);
    backdrop-filter: blur(8px);
  }
  .site-header.is-scrolled .site-header__inner::after {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__inner,
    .site-header__inner::after {
      transition: none;
    }
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    flex: none;
    grid-column: 1;
    min-width: 32px;
    line-height: 0;
  }
  /* OptimizedImage renders <picture><img> — :global so scoped styles still apply. */
  .site-header__logo :global(picture) {
    display: block;
    flex: none;
    min-width: 32px;
  }
  .site-header__logo :global(img) {
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 12px;
    display: block;
    object-fit: contain;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    white-space: nowrap;
  }
  @media (min-width: 640px) {
    .site-header__inner {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .site-header__logo {
      position: relative;
      z-index: 1;
      flex: none;
    }
    .site-header__nav {
      display: flex;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      pointer-events: auto;
    }
    .site-header__actions {
      position: relative;
      z-index: 1;
      flex: none;
      margin-left: auto;
    }
  }
  .site-header__link {
    font-size: 0.875rem;
    color: var(--color-ink-soft);
    white-space: nowrap;
    transition: color 150ms ease;
  }
  .site-header__link:hover {
    color: var(--color-ink);
  }

  .site-header__cta {
    flex: none;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.5rem;
    flex: none;
    grid-column: 2;
    white-space: nowrap;
    /* Matches .btn-pill vertical box (padding + line-height + border). */
    --site-header-control-h: calc(0.4rem * 2 + 1.2 * 0.875rem + 2px);
  }

  .site-header__menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    box-sizing: border-box;
    width: var(--site-header-control-h);
    height: var(--site-header-control-h);
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    background: var(--color-card);
    color: var(--color-ink);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .site-header__menu-toggle:hover {
    background: var(--color-warm);
  }
  .site-header__menu-toggle-label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .site-header__menu-icon--close {
    display: none;
  }
  .site-header.is-menu-open .site-header__menu-icon--open {
    display: none;
  }
  .site-header.is-menu-open .site-header__menu-icon--close {
    display: block;
  }
  @media (min-width: 640px) {
    .site-header__menu-toggle {
      display: none;
    }
  }

  .site-header__mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 90;
  }
  .site-header__mobile-nav:not(.is-open) {
    visibility: hidden;
    pointer-events: none;
  }
  .site-header__mobile-nav.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .site-header__mobile-nav-backdrop {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: 0;
    background: rgba(15, 23, 42, 0.28);
    opacity: 0;
    cursor: pointer;
    transition: opacity var(--header-duration) var(--header-ease);
  }
  .site-header.is-menu-open .site-header__mobile-nav-backdrop {
    opacity: 1;
  }

  .site-header__mobile-nav-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    width: min(100%, 18.5rem);
    padding:
      calc(4.25rem + env(safe-area-inset-top, 0px))
      1.25rem
      calc(1.25rem + env(safe-area-inset-bottom, 0px));
    background: var(--color-paper);
    border-left: 1px solid var(--color-rule);
    box-shadow: -8px 0 32px -12px rgba(15, 23, 42, 0.12);
    transform: translateX(100%);
    transition: transform var(--header-duration) var(--header-ease);
  }
  .site-header__mobile-nav.is-open .site-header__mobile-nav-panel {
    transform: translateX(0);
  }

  .site-header__mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .site-header__mobile-link {
    display: block;
    padding: 0.75rem 0.5rem;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: 0.75rem;
    transition: background-color 150ms ease, color 150ms ease;
  }
  .site-header__mobile-link:hover {
    background: var(--color-warm);
    color: var(--color-ink);
  }
  .site-header__mobile-cta {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__mobile-nav-backdrop,
    .site-header__mobile-nav-panel {
      transition: none;
    }
  }
  @media (min-width: 640px) {
    .site-header__mobile-nav {
      display: none;
    }
  }
</style>

<script>
  // Toggle .is-scrolled once the page scrolls past a small threshold,
  // animating the header from the flat top-of-page bar into the floating
  // pill (see scoped <style> above). rAF-ticked to avoid scroll jank,
  // matching the pattern used elsewhere in this codebase (see
  // UseCasesPreview.astro's track-scroll listener).
  const header = document.getElementById("site-header");
  if (header) {
    const inner = header.querySelector(".site-header__inner");
    const threshold = Number(header.dataset.scrollThreshold) || 16;
    let scrollTicking = false;
    let resizeTicking = false;

    const measurePillWidth = (forScrolled = header.classList.contains("is-scrolled")) => {
      if (!inner) return;
      const style = getComputedStyle(inner);
      const pillInset = 12; // 0.75rem — matches --pill-inset
      const gap = forScrolled ? pillInset : parseFloat(style.columnGap || style.gap) || 0;
      const paddingX = forScrolled ? pillInset * 2 : parseFloat(style.paddingLeft) + parseFloat(style.paddingRight);
      const borderX = parseFloat(style.borderLeftWidth) + parseFloat(style.borderRightWidth);

      const measureNavWidth = (nav) => {
        const navStyle = getComputedStyle(nav);
        const navGap = parseFloat(navStyle.columnGap || navStyle.gap) || 0;
        const links = [...nav.querySelectorAll("a")].filter(
          (link) => getComputedStyle(link).display !== "none" && link.offsetParent !== null
        );
        if (links.length === 0) return 0;
        const linksWidth = links.reduce((sum, link) => sum + link.getBoundingClientRect().width, 0);
        return linksWidth + Math.max(0, links.length - 1) * navGap;
      };

      const measureActionsWidth = (actions) => {
        const actionStyle = getComputedStyle(actions);
        const actionGap = parseFloat(actionStyle.columnGap || actionStyle.gap) || 0;
        const items = [...actions.children].filter(
          (child) => getComputedStyle(child).display !== "none"
        );
        if (items.length === 0) return 0;
        const itemsWidth = items.reduce((sum, child) => sum + child.getBoundingClientRect().width, 0);
        return itemsWidth + Math.max(0, items.length - 1) * actionGap;
      };

      const logo = inner.querySelector(".site-header__logo");
      const nav = inner.querySelector(".site-header__nav");
      const actions = inner.querySelector(".site-header__actions");

      const logoWidth = logo && getComputedStyle(logo).display !== "none" ? 32 : 0;
      const navWidth = nav && getComputedStyle(nav).display !== "none" ? measureNavWidth(nav) : 0;
      const actionsWidth =
        actions && getComputedStyle(actions).display !== "none" ? measureActionsWidth(actions) : 0;

      let contentWidth;
      if (navWidth > 0) {
        // Grid is 1fr auto 1fr — pill needs symmetric flanks so centered nav clears both sides.
        const flankWidth = Math.max(logoWidth, actionsWidth);
        contentWidth = navWidth + 2 * flankWidth + 2 * gap;
      } else {
        contentWidth = logoWidth + actionsWidth + gap;
      }

      const pillWidth = contentWidth + paddingX + borderX;
      if (pillWidth > 0) {
        header.style.setProperty("--pill-width", `${pillWidth}px`);
      }
    };

    const updateScrolled = () => {
      const scrolled = window.scrollY > threshold;
      if (scrolled) measurePillWidth(true);
      header.classList.toggle("is-scrolled", scrolled);
      scrollTicking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (scrollTicking) return;
        scrollTicking = true;
        requestAnimationFrame(updateScrolled);
      },
      { passive: true }
    );

    const menuToggle = document.getElementById("site-header-menu-toggle");
    const mobileNav = document.getElementById("site-header-mobile-nav");
    const mobileBackdrop = document.getElementById("site-header-mobile-backdrop");

    const setMenuOpen = (open) => {
      header.classList.toggle("is-menu-open", open);
      if (menuToggle) menuToggle.setAttribute("aria-expanded", open ? "true" : "false");
      if (mobileNav) {
        mobileNav.classList.toggle("is-open", open);
        mobileNav.setAttribute("aria-hidden", open ? "false" : "true");
      }
      document.documentElement.style.overflow = open ? "hidden" : "";
    };

    const closeMenu = () => setMenuOpen(false);
    const openMenu = () => setMenuOpen(true);

    menuToggle?.addEventListener("click", () => {
      if (header.classList.contains("is-menu-open")) closeMenu();
      else openMenu();
    });
    mobileBackdrop?.addEventListener("click", closeMenu);
    mobileNav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && header.classList.contains("is-menu-open")) closeMenu();
    });

    window.addEventListener(
      "resize",
      () => {
        if (resizeTicking) return;
        resizeTicking = true;
        requestAnimationFrame(() => {
          measurePillWidth();
          if (window.innerWidth >= 640 && header.classList.contains("is-menu-open")) closeMenu();
          resizeTicking = false;
        });
      },
      { passive: true }
    );

    updateScrolled();
    measurePillWidth();
  }
</script>
